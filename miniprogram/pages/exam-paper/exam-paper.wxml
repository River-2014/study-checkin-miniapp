<view class="paper-page">

  <!-- ===================== 阶段1：设置 ===================== -->
  <view class="setting-panel" wx:if="{{phase === 'setting'}}">

    <!-- 模式选择 -->
    <view class="mode-selector">
      <view class="mode-tab {{examMode === 'simulation' ? 'mode-active' : ''}}" data-mode="simulation" bindtap="switchExamMode">
        模拟生成
      </view>
      <view class="mode-tab {{examMode === 'real' ? 'mode-active' : ''}}" data-mode="real" bindtap="switchExamMode">
        真卷答题
      </view>
    </view>

    <!-- ===== 模拟生成模式 ===== -->
    <view class="card" wx:if="{{examMode === 'simulation'}}">
      <view class="filter-group">
        <view class="filter-row">
          <text class="filter-label">年级</text>
          <picker mode="selector" range="{{gradeList}}" value="{{gradeIndex}}" bindchange="onGradeChange">
            <view class="picker-value">{{gradeList[gradeIndex]}}</view>
          </picker>
        </view>
        <view class="filter-row">
          <text class="filter-label">科目</text>
          <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
            <view class="picker-value">{{subjects[subjectIndex]}}</view>
          </picker>
        </view>
        <view class="filter-row">
          <text class="filter-label">难度</text>
          <picker mode="selector" range="{{difficulties}}" value="{{difficultyIndex}}" bindchange="onDifficultyChange">
            <view class="picker-value">{{difficulties[difficultyIndex]}}</view>
          </picker>
        </view>
        <view class="filter-row">
          <text class="filter-label">时长</text>
          <picker mode="selector" range="{{['15分钟','20分钟','30分钟','45分钟','60分钟']}}" value="{{0}}" bindchange="onDurationChange">
            <view class="picker-value">{{duration}}分钟</view>
          </picker>
        </view>
      </view>

      <view class="filter-group">
        <text class="filter-label">题型分布（点击切换）</text>
        <view class="type-dist-grid">
          <view
            wx:for="{{typeDistribution}}"
            wx:for-item="conf"
            wx:for-index="i"
            wx:key="i"
            class="dist-item {{conf.selected ? 'dist-active' : ''}}"
            data-key="{{i}}"
            bindtap="onTypeToggle"
          >
            <text class="dist-type">{{i}}</text>
            <text class="dist-count">×{{conf.count}}</text>
          </view>
        </view>
      </view>

      <button class="btn btn-primary btn-block" bindtap="startExam" loading="{{loading}}" disabled="{{loading}}">
        📝 开始考试
      </button>
    </view>

    <!-- ===== 真卷答题模式 ===== -->
    <view wx:if="{{examMode === 'real'}}">

      <!-- 筛选栏 -->
      <view class="card">
        <view class="paper-filter">
          <picker mode="selector" range="{{subjects}}" bindchange="onPaperSubjectFilter">
            <text class="picker-link">{{paperFilter.subject || '全部学科'}}</text>
          </picker>
          <picker mode="selector" range="{{gradeList}}" bindchange="onPaperGradeFilter">
            <text class="picker-link">{{paperFilter.grade || '全部年级'}}</text>
          </picker>
          <input class="filter-search" placeholder="🔍 搜索试卷" value="{{paperFilter.keyword}}" data-field="keyword" bindinput="onPaperFilterChange" bindconfirm="searchPapers" />
        </view>
      </view>

      <!-- 试卷列表 -->
      <view class="paper-list-loading" wx:if="{{paperListLoading}}">
        <text>加载中...</text>
      </view>

      <view wx:if="{{!paperListLoading}}">
        <view class="empty-hint" wx:if="{{paperList.length === 0}}">
          <text>暂无试卷</text>
          <text class="empty-sub">请在管理员页面试卷管理 TAB 中创建试卷或通过 Excel 导入</text>
        </view>

        <view wx:for="{{paperList}}" wx:key="_id" class="paper-card" data-id="{{item._id}}" bindtap="selectPaper">
          <view class="paper-card-head">
            <text class="paper-title">{{item.title}}</text>
          </view>
          <view class="paper-card-meta">
            <text>{{item.subject}} · {{item.grade}}</text>
            <text wx:if="{{item.version}}">{{item.version}}</text>
            <text wx:if="{{item.questionCount > 0}}">共 {{item.questionCount}} 题</text>
            <text wx:if="{{item.totalScore > 0}}">{{item.totalScore}} 分</text>
            <text wx:if="{{item.duration > 0}}">{{item.duration}} 分钟</text>
            <text wx:if="{{item.year}}">{{item.year}}</text>
          </view>
          <view class="paper-card-tap">点击开始答题 →</view>
        </view>

        <!-- 分页 -->
        <view class="pagination" wx:if="{{paperTotal > 20}}">
          <button class="btn btn-small" bindtap="prevPaperPage" disabled="{{paperPage <= 1}}">上一页</button>
          <text class="page-info">{{paperPage}} / {{Math.ceil(paperTotal / 20) || 1}}</text>
          <button class="btn btn-small" bindtap="nextPaperPage" disabled="{{paperPage * 20 >= paperTotal}}">下一页</button>
        </view>
      </view>
    </view>

  </view>

  <!-- ===================== 阶段2：答题 ===================== -->
  <view class="answering-panel" wx:if="{{phase === 'answering'}}">
    <!-- 顶部栏 -->
    <view class="exam-topbar">
      <text class="back-link" bindtap="goToSetting">← 退出</text>
      <text class="exam-title" wx:if="{{paper}}">{{paper.name || paper.title || '试卷'}}</text>
      <text class="countdown {{remainingSeconds <= 60 ? 'countdown-warn' : ''}}">⏱ {{remainingStr}}</text>
    </view>

    <!-- 进度条 -->
    <view class="question-progress">
      <view class="progress-info">
        <text>{{currentIndex + 1}} / {{questions.length}}</text>
        <text class="submit-early" bindtap="submitExam">交卷</text>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{questions.length > 0 ? (currentIndex + 1) / questions.length * 100 : 0}}%"></view>
      </view>
    </view>

    <!-- 题目 Swiper -->
    <swiper
      current="{{currentIndex}}"
      bindchange="onSwiperChange"
      class="question-swiper"
    >
      <swiper-item wx:for="{{questions}}" wx:key="_id">
        <scroll-view scroll-y class="question-scroll">
          <view class="question-card">
            <view class="q-header">
              <text class="q-num">{{item.position || index + 1}}.</text>
              <text class="q-type-tag">{{item.type}}</text>
              <text class="q-pts" wx:if="{{!showResult}}">（{{scorePerType[item.type] || 3}}分）</text>
            </view>

            <view class="q-stem">{{item.stem}}</view>

            <!-- 选择题 -->
            <view class="options" wx:if="{{item.type === '选择题' && item.options && item.options.length > 0}}">
              <view
                wx:for="{{item.options}}"
                wx:for-item="opt"
                wx:for-index="optIdx"
                wx:key="optIdx"
                class="option {{userAnswers[item._id] === ['A','B','C','D','E','F'][optIdx] ? 'option-selected' : ''}} {{showResult && optIdx === item._correctOptIdx ? 'option-correct' : ''}} {{showResult && userAnswers[item._id] === ['A','B','C','D','E','F'][optIdx] && optIdx !== item._correctOptIdx ? 'option-wrong' : ''}}"
                data-qid="{{item._id}}"
                data-label="{{['A','B','C','D','E','F'][optIdx]}}"
                bindtap="selectOption"
              >
                <text class="opt-label">{{['A','B','C','D','E','F'][optIdx]}}.</text>
                <text class="opt-text">{{opt}}</text>
              </view>
            </view>

            <!-- 判断题 -->
            <view class="judge-section" wx:if="{{item.type === '判断题'}}">
              <view class="judge-btns">
                <view class="judge-btn {{userAnswers[item._id] === '√' ? 'judge-active' : ''}}" data-qid="{{item._id}}" data-val="√" bindtap="selectJudge">✓ 正确</view>
                <view class="judge-btn {{userAnswers[item._id] === '×' ? 'judge-active judge-wrong' : ''}}" data-qid="{{item._id}}" data-val="×" bindtap="selectJudge">✗ 错误</view>
              </view>
            </view>

            <!-- 填空题 -->
            <view class="blank-section" wx:if="{{item.type === '填空题'}}">
              <input class="blank-input" placeholder="请输入你的答案" value="{{userAnswers[item._id] || ''}}" data-qid="{{item._id}}" bindinput="fillBlank" disabled="{{showResult}}" />
            </view>

            <!-- 简答题 -->
            <view class="essay-section" wx:if="{{item.type === '简答题'}}">
              <textarea class="essay-textarea" placeholder="请输入你的解答..." value="{{userAnswers[item._id] || ''}}" data-qid="{{item._id}}" bindinput="fillBlank" maxlength="500" disabled="{{showResult}}" />
            </view>

            <!-- 解析 -->
            <view class="analysis" wx:if="{{showResult}}">
              <view class="correct-badge" wx:if="{{item._isCorrect}}">✅ 你的答案：{{userAnswers[item._id]}}  回答正确</view>
              <block wx:else>
                <view class="wrong-badge">❌ 你的答案：{{userAnswers[item._id] || '（未作答）'}}</view>
                <view class="correct-answer">✅ 正确答案：{{item.answer}}</view>
              </block>
              <view class="analysis-text" wx:if="{{item.explanation}}">📖 解析：{{item.explanation}}</view>
            </view>
          </view>
        </scroll-view>
      </swiper-item>
    </swiper>

    <!-- 提交栏 -->
    <view class="submit-bar" wx:if="{{!showResult}}">
      <button class="btn btn-outline btn-sm" style="flex:1; margin:0 8rpx;" bindtap="prevQuestion" disabled="{{currentIndex === 0}}">上一题</button>
      <button class="btn btn-outline btn-sm" style="flex:1; margin:0 8rpx;" bindtap="nextQuestion" disabled="{{currentIndex === questions.length - 1}}">下一题</button>
      <button class="btn btn-primary" style="flex:1.5; margin:0 8rpx;" bindtap="submitExam">交卷</button>
    </view>
  </view>

  <!-- ===================== 阶段3：成绩报告 ===================== -->
  <view class="result-panel" wx:if="{{phase === 'answering' && showResult}}">
    <view class="score-card">
      <text class="score-big">{{score}}</text>
      <text class="score-total">/ {{totalScore}} 分</text>
      <text class="score-rate">正确率 {{questions.length > 0 ? Math.round(correctCount / questions.length * 100) : 0}}%（{{correctCount}}/{{questions.length}}）</text>
    </view>

    <view class="card" wx:if="{{typeStats.length > 0}}">
      <view class="section-title">📊 各题型正确率</view>
      <chart-bar data="{{barData}}" options="{{barOptions}}"></chart-bar>
    </view>

    <view class="card" wx:if="{{knowledgeStats.length > 0}}">
      <view class="section-title">🎯 知识点掌握度</view>
      <chart-radar data="{{radarData}}" options="{{radarOptions}}"></chart-radar>
    </view>

    <view class="result-actions">
      <button class="btn btn-outline" bindtap="goToWrongbook">查看错题</button>
      <button class="btn btn-primary" bindtap="goToSetting">返回</button>
    </view>
  </view>

</view>
