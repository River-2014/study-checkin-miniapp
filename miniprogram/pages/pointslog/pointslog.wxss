/* ===== 积分明细样式 ===== */
.pl-page { padding-bottom: 30rpx; }

/* ===== 筛选 ===== */
.pl-filter {
  display: flex; padding: 20rpx; gap: 16rpx;
}
.pl-filter-tag {
  padding: 10rpx 32rpx; border-radius: 20rpx; font-size: 26rpx;
  background: #F0F0F0; color: #636E72;
}
.pl-active { background: #FF9F43; color: #fff; font-weight: 600; }

/* ===== 流水项 ===== */
.pl-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx; background: #fff; margin: 0 20rpx 12rpx;
  border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.pl-left { display: flex; flex-direction: column; gap: 6rpx; flex: 1; }
.pl-desc { font-size: 28rpx; color: #2D3436; }
.pl-time { font-size: 22rpx; color: #B2BEC3; }
.pl-amount { font-size: 34rpx; font-weight: 700; }
.pl-earn { color: #2ED573; }
.pl-spend { color: #FF6B6B; }
