/* ===== 日历页样式 ===== */
.calendar-page {
  padding: 20rpx 0 30rpx;
}

/* ===== 月份导航 ===== */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx;
  background: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.nav-arrow {
  font-size: 32rpx;
  color: #FF9F43;
  padding: 16rpx;
  font-weight: bold;
}

.nav-arrow:active {
  opacity: 0.6;
}

.month-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
}

/* ===== 星期表头 ===== */
.week-header {
  display: flex;
  margin: 0 24rpx;
  padding: 0 10rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #636E72;
  padding: 16rpx 0;
}

/* ===== 日期网格 ===== */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 24rpx;
  padding: 10rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.calendar-cell {
  width: 14.28%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-cell {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-cell.empty {
  visibility: hidden;
}

.day-cell.today {
  border: 3rpx solid #FF9F43;
  background: #FFF8E7;
}

.day-cell.has-checkin {
  background: #E8F8E8;
}

.day-cell.today.has-checkin {
  background: #E8F8E8;
  border-color: #FF9F43;
}

.day-num {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
}

.day-cell.today .day-num {
  font-weight: 700;
  color: #FF9F43;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2ED573;
  margin-top: 4rpx;
}

/* ===== 图例 ===== */
.legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 24rpx 0;
  margin: 0 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #636E72;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.legend-dot.green {
  background: #2ED573;
}

.legend-dot.orange-border {
  border: 3rpx solid #FF9F43;
  background: #FFF8E7;
}

/* ===== 统计卡片 ===== */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF9F43;
}

.stat-label {
  font-size: 22rpx;
  color: #636E72;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #F0F0F0;
}
