<view class="calendar-page">
  <!-- ===== 月份导航 ===== -->
  <view class="month-nav">
    <text class="nav-arrow" bindtap="prevMonth">◀</text>
    <text class="month-title">{{year}}年{{month}}月</text>
    <text class="nav-arrow" bindtap="nextMonth">▶</text>
  </view>

  <!-- ===== 星期表头 ===== -->
  <view class="week-header">
    <view wx:for="{{weekDays}}" wx:key="*this" class="week-day">{{item}}</view>
  </view>

  <!-- ===== 日期网格 ===== -->
  <view class="calendar-grid">
    <view wx:for="{{calendarDays}}" wx:key="index" class="calendar-cell"
      data-date="{{item.dateStr}}" bindtap="onDateTap">
      <view class="day-cell {{item.isToday ? 'today' : ''}} {{item.hasCheckin ? 'has-checkin' : ''}} {{item.isEmpty ? 'empty' : ''}}">
        <text class="day-num">{{item.day}}</text>
        <view wx:if="{{item.hasCheckin}}" class="day-dot"></view>
      </view>
    </view>
  </view>

  <!-- ===== 图例 ===== -->
  <view class="legend">
    <view class="legend-item">
      <view class="legend-dot green"></view>
      <text>已打卡</text>
    </view>
    <view class="legend-item">
      <view class="legend-dot orange-border"></view>
      <text>今天</text>
    </view>
  </view>

  <!-- ===== 统计 ===== -->
  <view class="card stats-card">
    <view class="stat-item">
      <text class="stat-num">{{checkinDays}}</text>
      <text class="stat-label">本月打卡天数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{totalCheckins}}</text>
      <text class="stat-label">累计打卡</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
