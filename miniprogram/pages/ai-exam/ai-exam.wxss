.container {
  padding: 20rpx 30rpx;
  background: #FFF8F0;
  min-height: 100vh;
}
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #FF6B35;
}
.form-item {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.label {
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}
.picker {
  color: #636E72;
  font-size: 28rpx;
}
slider {
  margin-top: 10rpx;
}
.btn-primary {
  background: #FF6B35;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.btn-secondary {
  background: #F0F0F0;
  color: #2D3436;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.switch-item .label { margin-bottom: 0; }
.stream-status {
  text-align: center;
  color: #FF6B35;
  font-size: 26rpx;
  padding: 10rpx 0;
}
.tip {
  text-align: center;
  color: #B2BEC3;
  font-size: 22rpx;
  margin-top: 16rpx;
}

/* 答题界面 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 0;
}
.back-btn {
  color: #FF6B35;
  font-size: 28rpx;
}
.progress-text {
  color: #636E72;
  font-weight: bold;
}
.question-swiper {
  height: 70vh;
}
.question-content {
  padding: 20rpx;
}
.q-header {
  margin-bottom: 20rpx;
  color: #636E72;
  font-size: 24rpx;
}
.q-type {
  color: #FF6B35;
  font-weight: bold;
}
.q-diff {
  background: #FFF3E0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.q-body {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
  line-height: 1.6;
}
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option {
  background: white;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #EFEFEF;
  transition: 0.2s;
}
.option.selected {
  border-color: #FF6B35;
  background: #FFF3E0;
}
.option.correct {
  border-color: #2ECC71;
  background: #F0FFF4;
}
.option.wrong {
  border-color: #E74C3C;
  background: #FFECEC;
}
.opt-label {
  font-weight: bold;
  margin-right: 12rpx;
  color: #FF6B35;
}
.opt-text {
  font-size: 28rpx;
}
.fill-blank {
  margin-top: 20rpx;
}
.blank-input, .app-textarea {
  border: 2rpx solid #DFE6E9;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}
.app-textarea {
  height: 200rpx;
}
.analysis {
  margin-top: 30rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 20rpx;
}
.correct-badge, .wrong-badge {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}
.correct-badge { color: #2ECC71; }
.wrong-badge { color: #E74C3C; }
.correct-answer {
  font-weight: bold;
  font-size: 28rpx;
  color: #2ECC71;
  margin-bottom: 8rpx;
}
.analysis-text, .exam-point {
  font-size: 26rpx;
  color: #636E72;
  margin-top: 8rpx;
  line-height: 1.5;
}
/* 听力填空 */
.listening-section {
  margin-top: 20rpx;
  background: #F0F7FF;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #D6E4FF;
}
.listening-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.listening-icon { font-size: 36rpx; }
.listening-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #54A0FF;
}
.btn-play {
  background: #54A0FF;
  color: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border: none;
  text-align: center;
}
.btn-play:active { opacity: 0.8; }
.listening-script {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #54A0FF;
}
.script-label {
  font-size: 22rpx;
  color: #B2BEC3;
  display: block;
  margin-bottom: 8rpx;
}
.script-text {
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
}

/* 朗读题 */
.speak-section { margin-top: 20rpx; }
.speak-text {
  font-size: 34rpx; font-weight: 700; color: #2D3436;
  padding: 24rpx; background: #F0F7FF; border-radius: 16rpx;
  border-left: 6rpx solid #54A0FF; margin-bottom: 16rpx; line-height: 1.6;
}
.speak-translation {
  font-size: 24rpx; color: #B2BEC3; margin-bottom: 16rpx; padding: 0 8rpx;
}
.btn-speak {
  width: 100%; border-radius: 30rpx; font-size: 28rpx; padding: 20rpx 0;
  margin-bottom: 12rpx; text-align: center; color: #fff;
  background: linear-gradient(135deg, #54A0FF, #A29BFE);
}
.btn-speak:active { opacity: 0.8; }
.btn-speak-rec { background: linear-gradient(135deg, #FF6B6B, #E17055); }
.btn-speak-play { background: #2ED573; }
.btn-speak-submit { background: linear-gradient(135deg, #FF9F43, #F39C12); }
.speak-actions { display: flex; gap: 16rpx; }
.speak-actions .btn-speak { flex: 1; padding: 16rpx 0; font-size: 26rpx; margin-bottom: 0; }
.speak-result {
  background: #F8F9FA; border-radius: 16rpx; padding: 20rpx; margin-top: 12rpx;
}
.speak-score { font-size: 32rpx; font-weight: 700; color: #FF6B35; display: block; margin-bottom: 8rpx; }
.speak-suggestion { font-size: 26rpx; color: #636E72; display: block; }

/* 作文题 */
.essay-section { margin-top: 20rpx; }
.essay-input {
  width: 100%; height: 300rpx; border: 2rpx solid #DFE6E9;
  border-radius: 16rpx; padding: 20rpx; font-size: 28rpx;
  box-sizing: border-box; line-height: 1.6; margin-top: 16rpx;
}

.print-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 2000px; }
.bottom-bar {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  gap: 20rpx;
}
.bottom-bar button {
  flex: 1;
  margin: 0;
}
