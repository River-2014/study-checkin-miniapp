.family-page {
  min-height: 100vh;
  background: #FFF8E7;
  padding: 30rpx;
}
.family-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.family-section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2D3436;
  margin-bottom: 24rpx;
}
.family-code-area {
  text-align: center;
  padding: 30rpx;
  background: #FFF8E7;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.family-code-label {
  font-size: 24rpx;
  color: #636E72;
  display: block;
  margin-bottom: 12rpx;
}
.family-code-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF9F43;
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 12rpx;
}
.family-code-hint {
  font-size: 22rpx;
  color: #B2BEC3;
  display: block;
}
.btn-primary {
  background: #FF9F43;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
  width: 100%;
  text-align: center;
}
.btn-outline {
  background: #FFFFFF;
  color: #FF9F43;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
  width: 100%;
  text-align: center;
  border: 2rpx solid #FF9F43;
  margin-top: 20rpx;
}
.btn-outline[disabled] {
  opacity: 0.4;
}
.family-divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 30rpx 0;
}
.family-empty {
  text-align: center;
  color: #B2BEC3;
  font-size: 26rpx;
  padding: 40rpx 0;
}
.family-member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F8F8F8;
}
.family-member-item:last-child {
  border-bottom: none;
}
.member-avatar {
  font-size: 48rpx;
  margin-right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.member-info {
  flex: 1;
}
.member-name {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}
.family-code-input {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  text-align: center;
  letter-spacing: 12rpx;
}

/* ===== TAB 切换 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #636E72;
  border-radius: 12rpx;
  transition: all 0.3s;
}
.tab-active {
  background: #FF9F43;
  color: #fff;
  font-weight: bold;
}

/* ===== 契约模板 ===== */
.contract-tpl-list { display: flex; flex-direction: column; gap: 12rpx; }
.contract-tpl-item {
  display: flex; align-items: center; padding: 16rpx 20rpx;
  background: #F8F8F8; border-radius: 12rpx;
}
.contract-tpl-item:active { background: #F0E6FF; }
.tpl-left { flex: 1; }
.tpl-title { font-size: 28rpx; color: #2D3436; font-weight: 500; display: block; }
.tpl-desc { font-size: 22rpx; color: #B2BEC3; }
.tpl-arrow { font-size: 32rpx; color: #6C5CE7; font-weight: bold; }

/* ===== 契约列表项 ===== */
.contract-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F8F8F8;
}
.contract-item:last-child { border-bottom: none; }
.ct-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.ct-title { font-size: 28rpx; font-weight: 500; color: #2D3436; }
.ct-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 12rpx; }
.ct-pending { background: #FFF8E1; color: #F39C12; }
.ct-active { background: #E8F5E9; color: #2E7D32; }
.ct-completed { background: #F0E6FF; color: #6C5CE7; }
.ct-rejected { background: #FFEBEE; color: #C62828; }
.ct-body { display: flex; justify-content: space-between; font-size: 24rpx; color: #636E72; margin-bottom: 8rpx; }
.ct-bar { height: 8rpx; background: #F0F0F0; border-radius: 4rpx; margin-bottom: 12rpx; }
.ct-bar-fill { height: 100%; background: linear-gradient(90deg, #6C5CE7, #A29BFE); border-radius: 4rpx; transition: width 0.5s; }
.ct-actions { display: flex; gap: 12rpx; }
