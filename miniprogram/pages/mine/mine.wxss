/* ===== 我的页样式 ===== */
.mine-page { padding-bottom: 30rpx; }

/* ===== 分组容器 ===== */
.section-group { margin-bottom: 8rpx; }
.group-header { padding: 16rpx 28rpx 8rpx; }
.group-title { font-size: var(--font-sm); color: var(--text-hint); font-weight: 600; }
.group-body { display: flex; flex-direction: column; }
.fold-trigger { display: flex; justify-content: space-between; align-items: center; }
.fold-arrow { font-size: var(--font-xs); color: var(--text-hint); }

/* ===== 统计卡片 ===== */
.stat-row {
  display: flex;
  justify-content: space-around;
}

.stat-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: var(--font-xxl);
  font-weight: 800;
  color: var(--color-primary);
}

.stat-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 卡片内容 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
}

.danger-title {
  color: var(--color-error);
}

/* ===== 徽章网格 ===== */
.badge-grid {
  display: flex;
  flex-wrap: wrap;
}

.badge-cell {
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 12rpx 8rpx;
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  text-align: center;
  border: 2rpx solid #FFEAA7;
}

.badge-cell-icon {
  font-size: var(--font-xl);
}

.badge-cell-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.badge-cell-desc {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-hint);
  text-align: center;
  padding: 20rpx 0;
}

/* ===== 成长档案 ===== */
.growth-timeline { padding: 8rpx 0 16rpx; }
.growth-node { display: flex; align-items: flex-start; gap: 12rpx; padding: 8rpx 0; }
.gn-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--color-primary); margin-top: 6rpx; flex-shrink: 0; }
.gn-content { display: flex; flex-direction: column; gap: 2rpx; }
.gn-label { font-size: var(--font-sm); color: var(--text-primary); font-weight: 600; }
.gn-grade { font-size: var(--font-xs); color: var(--color-primary); }
.gn-date { font-size: var(--font-xs); color: var(--text-hint); }
.growth-stats { display: flex; flex-wrap: wrap; gap: 8rpx 20rpx; padding-top: 8rpx; border-top: 1rpx solid var(--border-color); }
.gs-item { font-size: var(--font-xs); color: var(--text-secondary); }

/* ===== 危险操作 ===== */
.danger-card {
  border: 2rpx solid var(--color-error-light);
}

.dev-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}


/* ===== 表单 ===== */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: var(--bg-gray);
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
  box-sizing: border-box;
  border: 2rpx solid var(--border-color);
}

/* ===== 分类选择 ===== */
.category-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-tag {
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  font-size: var(--font-sm);
  background: var(--border-color);
  color: var(--text-secondary);
}

.category-tag.cat-selected {
  background: var(--bg-page);
  color: var(--color-primary);
  font-weight: 600;
  border: 2rpx solid var(--color-primary);
}

/* ===== Emoji选择器 ===== */
.emoji-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.emoji-tag {
  font-size: var(--font-xl);
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: var(--bg-gray);
  border: 2rpx solid transparent;
}

.emoji-tag.emoji-selected {
  background: var(--bg-page);
  border-color: var(--color-primary);
}

/* ===== 任务类型 ===== */
.task-type-row { display: flex; gap: 16rpx; }
.task-type-tag { flex: 1; padding: 14rpx 0; border-radius: 16rpx; font-size: var(--font-sm); background: var(--border-color); color: var(--text-secondary); text-align: center; }
.task-type-tag.tt-active { background: var(--color-accent-light); color: var(--text-on-primary); font-weight: 600; }

/* ===== 学科选择（迷你） ===== */
.subject-picker-mini { display: flex; gap: 16rpx; }
.sub-mini-tag { flex: 1; padding: 14rpx 0; border-radius: 16rpx; font-size: var(--font-sm); background: var(--border-color); color: var(--text-secondary); text-align: center; }
.sub-mini-tag.sub-active { background: var(--color-primary); color: var(--text-on-primary); font-weight: 600; }

/* ===== 提醒设置 ===== */
.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--bg-gray);
}

.reminder-row:last-child {
  border-bottom: none;
}

.mine-hint { font-size: 24rpx; color: var(--text-hint); display: block; margin-top: -8rpx; }
.reminder-label {
  font-size: var(--font-md);
  color: var(--text-primary);
}

.reminder-time {
  font-size: var(--font-md);
  color: var(--color-primary);
  font-weight: 600;
  padding: 8rpx 24rpx;
  background: var(--bg-page);
  border-radius: 12rpx;
}

/* ===== 奖励图片预览 ===== */
.reward-img-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-top: 12rpx;
  border: 2rpx solid var(--border-color);
}

/* ===== 孩子账号 ===== */
.child-list { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 10rpx; }
.child-item {
  padding: 12rpx 20rpx; border-radius: 16rpx; font-size: var(--font-sm);
  background: var(--border-color); color: var(--text-secondary); display: flex; align-items: center; gap: 8rpx;
}
.child-item.child-active { background: var(--bg-page); color: var(--color-primary); font-weight: 600; border: 2rpx solid var(--color-primary); }
.child-check { font-size: 24rpx; }

/* ===== 云备份按钮 ===== */
.btns-row { margin-top: 8rpx; }

/* ===== 弹窗按钮 ===== */
.modal-actions {
  margin-top: 32rpx;
}
