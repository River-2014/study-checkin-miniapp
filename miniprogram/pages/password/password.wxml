<view class="password-page">
  <view class="pwd-header">
    <text class="pwd-title">🔒 家长模式</text>
    <text class="pwd-hint">请输入4位数字密码</text>
  </view>

  <!-- ===== 密码圆点 ===== -->
  <view class="dot-row">
    <view wx:for="{{4}}" wx:key="*this" class="pwd-dot {{inputLen > index ? 'filled' : ''}}"></view>
  </view>

  <!-- ===== 错误提示 ===== -->
  <text wx:if="{{errorMsg}}" class="error-text">{{errorMsg}}</text>

  <!-- ===== 数字键盘 ===== -->
  <view class="keypad">
    <view wx:for="{{keys}}" wx:key="*this" class="key-btn {{item === '' ? 'key-empty' : ''}}"
      data-value="{{item}}" bindtap="onKeyTap">
      <text>{{item}}</text>
    </view>
  </view>

  <view class="pwd-footer">
    <text class="forgot-link" bindtap="onForgot">忘记密码？</text>
  </view>
</view>
