<view class="lb-page">
  <!-- TAB 切换 -->
  <view class="lb-tabs">
    <view class="lb-tab {{tab === 0 ? 'active' : ''}}" data-index="0" bindtap="switchTab">🔥 连续打卡</view>
    <view class="lb-tab {{tab === 1 ? 'active' : ''}}" data-index="1" bindtap="switchTab">⭐ 累计积分</view>
  </view>

  <!-- 未加入排行榜 -->
  <view class="lb-optin" wx:if="{{!optedIn}}">
    <text class="lb-optin-title">加入排行榜，看看你在第几名！</text>
    <text class="lb-optin-desc">仅展示连续打卡天数和累计积分，不显示具体任务内容</text>
    <button class="lb-optin-btn" bindtap="optIn">加入排行榜</button>
  </view>

  <!-- 榜单 -->
  <block wx:if="{{optedIn}}">
    <view class="lb-list">
      <view class="lb-item {{item.rank <= 3 ? 'top-' + item.rank : ''}}" wx:for="{{currentList}}" wx:key="rank">
        <view class="lb-rank">{{item.medal}}</view>
        <view class="lb-info">
          <text class="lb-name">{{item.nickname}}</text>
          <text class="lb-sub" wx:if="{{tab === 0}}">最长 {{item.longestStreak}} 天</text>
        </view>
        <view class="lb-value">
          <text class="lb-num">{{tab === 0 ? item.streak : item.stars}}</text>
          <text class="lb-unit">{{tab === 0 ? '天' : '⭐'}}</text>
        </view>
      </view>
      <view wx:if="{{currentList.length === 0}}" class="lb-empty">暂无数据，快去打卡吧！</view>
    </view>
    <view class="lb-footer">
      <button size="mini" type="default" bindtap="optOut">退出排行榜</button>
    </view>
  </block>
</view>
