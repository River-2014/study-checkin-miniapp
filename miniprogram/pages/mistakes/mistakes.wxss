/* ===== 错题本样式 ===== */
.mistakes-page { padding-bottom: 30rpx; }

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex; flex-wrap: wrap; padding: 16rpx 20rpx; gap: 12rpx;
}
.filter-tag {
  padding: 8rpx 24rpx; border-radius: 20rpx; font-size: var(--font-sm);
  background: var(--border-color); color: var(--text-secondary);
}
.filter-active { background: var(--color-primary); color: var(--text-on-primary); font-weight: 600; }

/* ===== 错题卡片 ===== */
.mistake-list { padding: 0 20rpx; }
.mistake-card {
  background: var(--bg-card); border-radius: 20rpx; padding: 24rpx;
  margin-bottom: 16rpx; box-shadow: 0 4rpx 20rpx var(--bg-overlay);
}
.mistake-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.mistake-subject { font-size: var(--font-xs); padding: 2rpx 16rpx; border-radius: 8rpx; color: var(--text-on-primary); }
.mistake-date { font-size: var(--font-xs); color: var(--text-hint); }
.mistake-reviewed { font-size: var(--font-xs); color: var(--color-success); margin-left: auto; }
.mistake-thumb { width: 200rpx; height: 150rpx; border-radius: 12rpx; overflow: hidden; margin-bottom: 10rpx; }
.mistake-thumb image { width: 100%; height: 100%; }
.mistake-note { font-size: var(--font-sm); color: var(--text-secondary); display: block; margin-bottom: 8rpx; }
.mistake-task-ref { font-size: 24rpx; color: var(--text-hint); display: block; }

/* ===== 复习按钮栏 ===== */
.review-bar { padding: 20rpx; }

/* ===== 复习弹窗 ===== */
.review-content {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 620rpx; max-height: 80vh; background: var(--bg-card);
  border-radius: 32rpx; padding: 40rpx; z-index: 200;
  display: flex; flex-direction: column; align-items: center;
}
.review-title { font-size: 36rpx; font-weight: 700; margin-bottom: 24rpx; }
.review-swiper { width: 100%; height: 500rpx; }
.review-card-inner {
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
  padding: 20rpx 0;
}
.review-img-wrap { width: 100%; }
.review-img { width: 100%; border-radius: 16rpx; }
.review-note { font-size: var(--font-md); color: var(--text-primary); text-align: center; }
.review-ref { font-size: 24rpx; color: var(--text-hint); }
.review-actions { margin-top: 24rpx; width: 100%; }

