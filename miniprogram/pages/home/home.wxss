/* ===== 首页样式 ===== */
.home-page {
  padding-bottom: 20rpx;
}

/* ===== 头部 ===== */
.header-section {
  background: linear-gradient(135deg, #FF9F43, #F39C12);
  padding: 40rpx 32rpx 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.sub-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
  display: block;
}

.stars-badge {
  background: rgba(255,255,255,0.25);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star-icon {
  font-size: 32rpx;
}

.star-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* ===== 连续打卡卡片 ===== */
.streak-card {
  margin-top: -40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
}

.streak-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.fire-icon {
  font-size: 64rpx;
  line-height: 1;
}

.fire-bounce {
  animation: fireBounce 1s ease-in-out infinite;
}

@keyframes fireBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.streak-info {
  display: flex;
  flex-direction: column;
}

.streak-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #FF9F43;
  line-height: 1.1;
}

.streak-label {
  font-size: 24rpx;
  color: #636E72;
}

.streak-right {
  text-align: center;
}

.longest-label {
  font-size: 22rpx;
  color: #B2BEC3;
  display: block;
}

.longest-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
}

/* ===== 进度条 ===== */
.progress-section {
  padding: 24rpx 28rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.progress-text {
  font-size: 24rpx;
  color: #636E72;
}

.progress-bar-bg {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2ED573, #7BED9F);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* ===== 任务列表 ===== */
.task-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
  padding: 10rpx 0 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.badge-more {
  font-size: 24rpx;
  font-weight: 400;
  color: #FF9F43;
}

.task-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.task-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.task-done {
  opacity: 0.7;
  background: #F9FFF9;
}

.task-done .task-name {
  text-decoration: line-through;
  color: #B2BEC3;
}

.task-icon {
  font-size: 48rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.task-done .task-icon {
  animation: popIn 0.3s ease;
}

@keyframes popIn {
  0% { transform: scale(0.5); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
}

.task-category {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
  color: #fff;
}

.tag-chinese { background: #FF9F43; }
.tag-math { background: #2ED573; }
.tag-english { background: #54A0FF; }
.tag-general { background: #A29BFE; }
.tag-sport { background: #FF6B6B; }
.tag-life { background: #FDCB6E; color: #2D3436; }

.task-points {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-right: 8rpx;
}

.points-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF9F43;
}

.points-unit {
  font-size: 24rpx;
}

/* ===== 任务右侧区域（练习按钮/状态标记） ===== */
.task-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.practice-go-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #54A0FF, #A29BFE);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.practice-go-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.go-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.go-arrow {
  font-size: 20rpx;
  color: #fff;
}

.task-done-mark {
  font-size: 36rpx;
}

.task-check-box {
  font-size: 36rpx;
  opacity: 0.4;
}

/* ===== 每日推荐练习 ===== */
.daily-plan {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin: 0 24rpx 16rpx;
  border-left: 6rpx solid #FF6B35;
}
.plan-header { font-size: 30rpx; font-weight: 700; color: #FF6B35; margin-bottom: 12rpx; }
.plan-content { display: flex; justify-content: space-between; align-items: center; }
.plan-left { display: flex; flex-direction: column; gap: 4rpx; }
.plan-subject { font-size: 28rpx; font-weight: 600; color: #2D3436; }
.plan-info { font-size: 22rpx; color: #636E72; }
.plan-btn {
  background: #FF6B35; color: white; border-radius: 30rpx;
  padding: 14rpx 28rpx; font-size: 26rpx; flex-shrink: 0; font-weight: 600;
}
.plan-btn:active { opacity: 0.8; }

/* ===== 成就徽章 ===== */
.badge-section {
  margin-top: 8rpx;
}

.badge-scroll {
  white-space: nowrap;
  padding: 10rpx 0;
  display: flex;
  flex-direction: row;
}

.badge-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  margin-right: 16rpx;
  text-align: center;
}

.badge-icon {
  font-size: 56rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FFF8E7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  border: 2rpx solid #FFEAA7;
}

.badge-locked .badge-icon {
  background: #F0F0F0;
  border-color: #DFE6E9;
  opacity: 0.5;
}

.badge-name {
  font-size: 22rpx;
  color: #636E72;
  white-space: normal;
  line-height: 1.3;
}

.badge-empty {
  font-size: 24rpx;
  color: #B2BEC3;
  padding: 20rpx 0;
  text-align: center;
}

.badge-locked .badge-name {
  color: #B2BEC3;
}

/* ===== 撒花动画 ===== */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
  overflow: hidden;
}

.confetti-piece {
  position: absolute;
  top: -60rpx;
  font-size: 36rpx;
  animation: confettiFall 1.2s ease-out forwards;
}

@keyframes confettiFall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(110vh) rotate(720deg);
    opacity: 0;
  }
}

/* ===== 鼓励语 Toast ===== */
.encourage-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.8);
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  z-index: 1000;
  pointer-events: none;
  animation: toastPop 0.3s ease;
}

@keyframes toastPop {
  0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0; }
  70% { transform: translate(-50%, -50%) scale(1.1); }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
}

/* ===== AI 出题入口 ===== */
.ai-exam-entry { padding: 0; }
.ai-exam-entry:active { transform: scale(0.97); }
.ai-exam-entry-inner {
  display: flex; align-items: center; gap: 20rpx; padding: 28rpx;
  background: linear-gradient(135deg, #A29BFE, #6C5CE7);
  border-radius: 20rpx;
}
.ai-exam-icon { font-size: 44rpx; }
.ai-exam-entry-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.ai-exam-entry-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.ai-exam-entry-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.ai-exam-arrow { font-size: 40rpx; color: rgba(255,255,255,0.7); }

/* ===== 错题本入口 ===== */
.wrongbook-entry { padding: 0; }
.wrongbook-entry:active { transform: scale(0.97); }
.wrongbook-entry-inner {
  display: flex; align-items: center; gap: 20rpx; padding: 28rpx;
  background: linear-gradient(135deg, #2ED573, #7BED9F);
  border-radius: 20rpx;
}
.wrongbook-icon { font-size: 44rpx; }
.wrongbook-entry-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.wrongbook-entry-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.wrongbook-entry-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.wrongbook-entry-arrow { font-size: 40rpx; color: rgba(255,255,255,0.7); }

/* ===== 首页家长中心入口 ===== */
.parent-entry-home { padding: 0; }
.parent-entry-home:active { transform: scale(0.97); }
.parent-entry-inner {
  display: flex; align-items: center; gap: 20rpx; padding: 28rpx;
  background: linear-gradient(135deg, #FF9F43, #F39C12);
  border-radius: 20rpx;
}
.parent-entry-icon { font-size: 44rpx; }
.parent-entry-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.parent-entry-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.parent-entry-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.parent-entry-arrow { font-size: 40rpx; color: rgba(255,255,255,0.7); }

/* ===== 学习看板 ===== */
.chart-section {
  padding: 24rpx 20rpx;
}

.chart-canvas {
  width: 100%;
  height: 300rpx;
}

/* ===== AI 建议 ===== */
.ai-section { padding: 24rpx 20rpx; }
.ai-advice { font-size: 26rpx; color: #636E72; line-height: 1.6; display: block; }
.ai-loading { font-size: 26rpx; color: #B2BEC3; display: block; }
.ai-empty { font-size: 26rpx; color: #B2BEC3; display: block; }

/* ===== 分享卡片 ===== */
.share-section {
  padding: 20rpx;
}
.share-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 560px;
  height: 400px;
}
