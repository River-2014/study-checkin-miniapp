/* ===== 首页样式 ===== */
.home-page { padding-bottom: 20rpx; }

/* ===== 考试倒计时 ===== */
.countdown-card { text-align: center; padding: 20rpx; }
.countdown-label { font-size: var(--font-sm); color: var(--text-hint); display: block; }
.countdown-days { font-size: 56rpx; font-weight: 800; color: var(--color-primary); display: block; }

/* ===== 骨架屏 ===== */
.skeleton-wrap { padding: 0 24rpx; }
.sk-header { height: 120rpx; margin: 24rpx 0; border-radius: 24rpx; }
.sk-card { height: 80rpx; margin-bottom: 16rpx; }
.sk-bar { height: 40rpx; margin-bottom: 24rpx; }
.sk-row { height: 100rpx; margin-bottom: 16rpx; }

/* ===== 头部 ===== */
.header-section {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary));
  padding: 40rpx 32rpx 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting-text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-on-primary);
  display: block;
}

.sub-text {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
  display: block;
}

.stars-badge {
  background: rgba(255,255,255,0.25);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star-icon {
  font-size: var(--font-lg);
}

.star-count {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-on-primary);
}

/* ===== 连续打卡卡片 ===== */
.streak-card {
  margin-top: -40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
}

.streak-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.fire-icon {
  font-size: 64rpx;
  line-height: 1;
}

/* 守护卡操作区 */
.guardian-bar {
  margin-top: 12rpx;
  padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 16rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}
.guardian-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
  min-width: 200rpx;
}
.guardian-actions { display: flex; gap: 12rpx; }
.guardian-btn {
  padding: 8rpx 20rpx;
  background: var(--color-primary);
  color: var(--text-on-primary);
  border-radius: 24rpx;
  font-size: 24rpx;
  white-space: nowrap;
}
.guardian-btn.buy { background: var(--color-accent); }
.guardian-btn:active { opacity: 0.8; }

.fire-bounce {
  animation: fireBounce 1s ease-in-out infinite;
}

@keyframes fireBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.streak-info {
  display: flex;
  flex-direction: column;
}

.streak-num {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1.1;
}

.streak-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.streak-right {
  text-align: center;
}

.longest-label {
  font-size: var(--font-xs);
  color: var(--text-hint);
  display: block;
}

.longest-num {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ===== 一键开始 Hero 卡片 ===== */
.next-task-card {
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.3);
}
.next-task-card:active { transform: scale(0.97); }
.next-task-label {
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.7);
  margin-bottom: 12rpx;
}
.next-task-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.next-task-icon { font-size: var(--font-xxl); }
.next-task-info { flex: 1; }
.next-task-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-on-primary);
}
.next-task-tags { display: flex; gap: 10rpx; margin-top: 6rpx; }
.next-task-tags .tag {
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: var(--font-xs);
  color: var(--text-on-primary);
  background: rgba(255,255,255,0.25);
}
.next-task-points {
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.85);
}
.next-task-btn {
  padding: 14rpx 32rpx;
  background: var(--bg-card);
  color: var(--color-accent);
  border-radius: 40rpx;
  font-size: var(--font-sm);
  font-weight: bold;
  white-space: nowrap;
}

/* 脉冲动画 */
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.5); }
  50% { box-shadow: 0 0 0 16rpx rgba(255,255,255,0); }
}
.pulse { animation: pulse 2s infinite; }

/* 全部完成卡片 */
.all-done-card {
  margin-top: 20rpx;
  padding: 40rpx 28rpx;
  background: linear-gradient(135deg, #00B894, #55EFC4);
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0, 184, 148, 0.3);
}
.all-done-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.all-done-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-on-primary);
  display: block;
}
.all-done-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 6rpx;
}

/* ===== 进度条 ===== */
.progress-section {
  padding: 24rpx 28rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-bar-bg {
  height: 16rpx;
  background: var(--border-color);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-success), #7BED9F);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* ===== 任务列表 ===== */
.task-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 10rpx 0 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.badge-more {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-primary);
}

.task-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx var(--bg-overlay);
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.task-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.task-done {
  opacity: 0.7;
  background: var(--color-success-light);
}

.task-done .task-name {
  text-decoration: line-through;
  color: var(--text-hint);
}

.task-icon {
  font-size: var(--font-xxl);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.task-done .task-icon {
  animation: popIn 0.3s ease;
}

@keyframes popIn {
  0% { transform: scale(0.5); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.task-category {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
  color: var(--text-on-primary);
}

.task-points {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-right: 8rpx;
}

.points-value {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
}

.points-unit {
  font-size: 24rpx;
}

/* ===== 任务右侧区域（练习按钮/状态标记） ===== */
.task-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.practice-go-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, var(--color-info), var(--color-accent-light));
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.practice-go-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.go-text {
  font-size: 24rpx;
  color: var(--text-on-primary);
  font-weight: 600;
}

.go-arrow {
  font-size: 20rpx;
  color: var(--text-on-primary);
}

.task-done-mark {
  font-size: 36rpx;
}

.task-check-box {
  font-size: 36rpx;
  opacity: 0.4;
}

/* ===== 每日推荐练习 ===== */
.daily-plan {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary-light));
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin: 0 24rpx 16rpx;
  border-left: 6rpx solid var(--color-primary-dark);
}
.plan-header { font-size: 30rpx; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 12rpx; }
.plan-content { display: flex; justify-content: space-between; align-items: center; }
.plan-left { display: flex; flex-direction: column; gap: 4rpx; }
.plan-subject { font-size: var(--font-md); font-weight: 600; color: var(--text-primary); }
.plan-info { font-size: var(--font-xs); color: var(--text-secondary); }
.plan-btn {
  background: var(--color-primary-dark); color: var(--text-on-primary); border-radius: 30rpx;
  padding: 14rpx 28rpx; font-size: var(--font-sm); flex-shrink: 0; font-weight: 600;
}
.plan-btn:active { opacity: 0.8; }

/* ===== 成就徽章 ===== */
.badge-section {
  margin-top: 8rpx;
}

.badge-scroll {
  white-space: nowrap;
  padding: 10rpx 0;
  display: flex;
  flex-direction: row;
}

.badge-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  margin-right: 16rpx;
  text-align: center;
}

.badge-icon {
  font-size: 56rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  border: 2rpx solid #FFEAA7;
}

.badge-locked .badge-icon {
  background: var(--border-color);
  border-color: var(--border-light);
  opacity: 0.5;
}

.badge-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  white-space: normal;
  line-height: 1.3;
}

.badge-empty {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 20rpx 0;
  text-align: center;
}

.badge-locked .badge-name {
  color: var(--text-hint);
}

/* ===== 撒花动画 ===== */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
  overflow: hidden;
}

.confetti-piece {
  position: absolute;
  top: -60rpx;
  font-size: 36rpx;
  animation: confettiFall 1.2s ease-out forwards;
}

@keyframes confettiFall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(110vh) rotate(720deg);
    opacity: 0;
  }
}

/* ===== 鼓励语 Toast ===== */
.encourage-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.8);
  color: var(--text-on-primary);
  padding: 20rpx 48rpx;
  border-radius: 20rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  z-index: 1000;
  pointer-events: none;
  animation: toastPop 0.3s ease;
}

@keyframes toastPop {
  0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0; }
  70% { transform: translate(-50%, -50%) scale(1.1); }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
}

/* ===== AI 出题入口 ===== */
.ai-exam-entry { padding: 0; }
.ai-exam-entry:active { transform: scale(0.97); }
.ai-exam-entry-inner {
  display: flex; align-items: center; gap: 20rpx; padding: 28rpx;
  background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent));
  border-radius: 20rpx;
}
.ai-exam-icon { font-size: 44rpx; }
.ai-exam-entry-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.ai-exam-entry-title { font-size: var(--font-lg); font-weight: 700; color: var(--text-on-primary); }
.ai-exam-entry-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.ai-exam-arrow { font-size: var(--font-xl); color: rgba(255,255,255,0.7); }

/* ===== 功能入口 2x2 网格 ===== */
.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 0 24rpx 16rpx;
}
.feature-cell {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: all 0.2s;
}
.feature-cell:active { transform: scale(0.95); }
.fc-icon { font-size: 44rpx; }
.fc-label { font-size: var(--font-sm); color: var(--text-primary); font-weight: 600; }

/* ===== 折叠面板 ===== */
.fold-panel { margin: 0 24rpx 16rpx; }
.fold-header {
  text-align: center;
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.fold-text { font-size: var(--font-sm); color: var(--text-secondary); font-weight: 500; }
.fold-body { margin-top: 12rpx; display: flex; flex-direction: column; gap: 12rpx; }

/* ===== 二级入口卡片 ===== */
.sub-entry-card { padding: 0; }
.sub-entry-card:active { transform: scale(0.97); }
.sub-entry-inner {
  display: flex; align-items: center; gap: 16rpx; padding: 22rpx 24rpx;
}
.sub-entry-icon { font-size: var(--font-xl); }
.sub-entry-text { flex: 1; display: flex; flex-direction: column; gap: 2rpx; }
.sub-entry-title { font-size: var(--font-md); font-weight: 600; color: var(--text-primary); }
.sub-entry-desc { font-size: var(--font-xs); color: var(--text-hint); }
.sub-entry-arrow { font-size: var(--font-lg); color: var(--text-hint); }

/* ===== 首页家长中心入口 ===== */
.parent-entry-home { padding: 0; }
.parent-entry-home:active { transform: scale(0.97); }
.parent-entry-inner {
  display: flex; align-items: center; gap: 20rpx; padding: 28rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary));
  border-radius: 20rpx;
}
.parent-entry-icon { font-size: 44rpx; }
.parent-entry-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.parent-entry-title { font-size: var(--font-lg); font-weight: 700; color: var(--text-on-primary); }
.parent-entry-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.parent-entry-arrow { font-size: var(--font-xl); color: rgba(255,255,255,0.7); }

/* ===== 学习看板 ===== */
.chart-section {
  padding: 24rpx 20rpx;
}

.chart-canvas {
  width: 100%;
  height: 300rpx;
}

/* ===== AI 建议 ===== */
.ai-section { padding: 24rpx 20rpx; }
.ai-advice { font-size: var(--font-sm); color: var(--text-secondary); line-height: 1.6; display: block; }
.ai-loading { font-size: var(--font-sm); color: var(--text-hint); display: block; }
.ai-empty { font-size: var(--font-sm); color: var(--text-hint); display: block; }

/* ===== 分享卡片 ===== */
.share-section {
  padding: 20rpx;
}
.share-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 560px;
  height: 400px;
}

/* ===== 亲子契约进度 ===== */
.contract-card {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
}
.contract-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.contract-icon { font-size: 36rpx; }
.contract-info { flex: 1; }
.contract-title { font-size: var(--font-sm); font-weight: bold; color: var(--text-primary); display: block; }
.contract-reward { font-size: var(--font-xs); color: var(--text-secondary); }
.contract-progress-badge {
  padding: 4rpx 16rpx;
  background: var(--color-accent-light);
  color: var(--color-accent);
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* 排行榜入口 */

/* ===== AI 推荐浮层 ===== */
.ai-recommend-overlay {
  position: fixed;
  inset: 0;
  background: var(--bg-mask);
  z-index: 900;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 40rpx;
}
.ai-recommend-card {
  width: 90%;
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.ai-rec-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.ai-rec-title { font-size: var(--font-lg); font-weight: bold; color: var(--text-primary); margin-bottom: 8rpx; }
.ai-rec-desc { font-size: 24rpx; color: var(--text-hint); margin-bottom: 28rpx; }
.ai-rec-actions { display: flex; gap: 16rpx; justify-content: center; }
.ai-rec-btn {
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: var(--font-md);
  background: var(--border-color);
  color: var(--text-secondary);
}
.share-card-popup { width: 85%; background: var(--bg-card); border-radius: 24rpx; padding: 24rpx; animation: slideUp 0.3s ease; }
.share-card-img { width: 100%; border-radius: 12rpx; }
.share-card-actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.share-btn { flex: 1; padding: 16rpx 0; border-radius: 40rpx; font-size: var(--font-md); text-align: center; background: var(--color-primary); color: var(--text-on-primary); }
.share-btn.close { background: var(--border-color); color: var(--text-secondary); }

.ai-rec-btn.primary {
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
  color: var(--text-on-primary);
  box-shadow: 0 4rpx 16rpx rgba(108,92,231,0.3);
}
