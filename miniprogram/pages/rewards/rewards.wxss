/* ===== 商城页样式 ===== */
.rewards-page {
  padding-bottom: 30rpx;
}

/* ===== 积分头部 ===== */
.stars-header {
  background: var(--gradient-primary);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stars-label {
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
}

.stars-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.star-big {
  font-size: 44rpx;
}

.star-count-big {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-on-primary);
}

/* ===== 奖励网格 ===== */
.reward-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}
.reward-grid > view {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.reward-card-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
}

.reward-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx var(--bg-overlay);
  transition: all 0.3s;
}

.reward-card:active {
  transform: scale(0.97);
}

.reward-icon {
  font-size: 64rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--bg-page);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reward-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

.reward-cost {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  background: var(--bg-page);
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
}

.reward-cost.cost-not-enough {
  color: var(--text-hint);
  background: var(--border-color);
}

/* ===== 空提示 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 24rpx 24rpx 16rpx;
}

/* ===== 公益捐赠 ===== */
.charity-grid { display: flex; flex-wrap: wrap; padding: 0 16rpx; gap: 12rpx; }
.charity-card {
  width: calc(50% - 22rpx);
  background: linear-gradient(135deg, var(--color-success-light), #C8E6C9);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.charity-card:active { transform: scale(0.97); }
.charity-icon { font-size: 48rpx; }
.charity-name { font-size: 26rpx; font-weight: 600; color: #2E7D32; }
.charity-cost { font-size: 24rpx; color: var(--color-success); font-weight: 500; }
.charity-notice { padding: 16rpx 24rpx; font-size: var(--font-xs); color: var(--text-hint); text-align: center; line-height: 1.6; }
