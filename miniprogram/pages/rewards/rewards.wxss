/* ===== 商城页样式 ===== */
.rewards-page {
  padding-bottom: 30rpx;
}

/* ===== 积分头部 ===== */
.stars-header {
  background: linear-gradient(135deg, #FF9F43, #F39C12);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stars-label {
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
}

.stars-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.star-big {
  font-size: 44rpx;
}

.star-count-big {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
}

/* ===== 奖励网格 ===== */
.reward-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}
.reward-grid > view {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.reward-card-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
}

.reward-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.reward-card:active {
  transform: scale(0.97);
}

.reward-icon {
  font-size: 64rpx;
  width: 100rpx;
  height: 100rpx;
  background: #FFF8E7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reward-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  text-align: center;
}

.reward-cost {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF9F43;
  background: #FFF8E7;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
}

.reward-cost.cost-not-enough {
  color: #B2BEC3;
  background: #F0F0F0;
}

/* ===== 空提示 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
  padding: 24rpx 24rpx 16rpx;
}
