<view class="rewards-page">
  <!-- 骨架屏 -->
  <view wx:if="{{!loaded}}" class="skeleton-wrap">
    <view class="sk-shimmer" style="height: 160rpx; border-radius: var(--radius-xl); margin-bottom: 16rpx;"></view>
    <view class="sk-shimmer skeleton--card" style="margin-bottom: 16rpx;"></view>
    <view class="sk-shimmer skeleton--card" style="margin-bottom: 16rpx;"></view>
  </view>

  <!-- ===== 积分余额 ===== -->
  <view class="stars-header">
    <text class="stars-label">我的星星</text>
    <view class="stars-display">
      <text class="star-big">⭐</text>
      <text class="star-count-big">{{stars}}</text>
    </view>
  </view>

  <!-- ===== 奖励列表 ===== -->
  <view class="section-title">🎁 兑换奖励</view>

  <view class="reward-grid">
    <view wx:for="{{rewards}}" wx:key="id" class="reward-card"
      data-id="{{item.id}}" bindtap="onRedeem"
      style="{{item.cost > stars ? 'opacity: 0.5;' : ''}}">
      <view class="reward-icon">
        <image wx:if="{{item.imageBase64}}" src="data:image/jpeg;base64,{{item.imageBase64}}" mode="aspectFill" class="reward-card-img" />
        <text wx:else>{{item.icon}}</text>
      </view>
      <text class="reward-name">{{item.name}}</text>
      <view class="reward-cost {{item.cost > stars ? 'cost-not-enough' : ''}}">
        <text>⭐ {{item.cost}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 公益捐赠 ===== -->
  <view class="section-title" style="margin-top: 20rpx;">🌍 公益捐赠</view>
  <view class="charity-grid">
    <view class="charity-card" bindtap="donate" data-type="tree">
      <text class="charity-icon">🌳</text>
      <text class="charity-name">种一棵树</text>
      <text class="charity-cost">100 ⭐</text>
    </view>
    <view class="charity-card" bindtap="donate" data-type="book">
      <text class="charity-icon">📚</text>
      <text class="charity-name">捐一本书</text>
      <text class="charity-cost">80 ⭐</text>
    </view>
    <view class="charity-card" bindtap="donate" data-type="meal">
      <text class="charity-icon">🍱</text>
      <text class="charity-name">爱心午餐</text>
      <text class="charity-cost">60 ⭐</text>
    </view>
    <view class="charity-card" bindtap="donate" data-type="class">
      <text class="charity-icon">🎓</text>
      <text class="charity-name">助学课堂</text>
      <text class="charity-cost">120 ⭐</text>
    </view>
  </view>

  <view class="charity-notice">📌 积分捐赠为虚拟公益行为，旨在培养孩子的社会责任感。积分由开发者记录，定期以实物形式兑现真实公益捐赠。</view>

  <view class="safe-bottom"></view>
</view>
