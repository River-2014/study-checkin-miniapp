{
  "pages": [
    "pages/home/home",
    "pages/calendar/calendar",
    "pages/rewards/rewards",
    "pages/mine/mine",
    "pages/mistakes/mistakes"
  ],
  "subpackages": [
    {
      "root": "subpkg-learn",
      "name": "learn",
      "pages": [
        "pages/ai-exam/ai-exam",
        "pages/practice/practice",
        "pages/exam-paper/exam-paper",
        "pages/wrongbook/wrongbook",
        "pages/pomodoro/pomodoro",
        "pages/leaderboard/leaderboard",
        "pages/pk/pk",
        "pages/weekly-report/weekly-report",
        "pages/badges/badges"
      ]
    },
    {
      "root": "subpkg-user",
      "name": "user",
      "pages": [
        "pages/detail/detail",
        "pages/pointslog/pointslog",
        "pages/password/password",
        "pages/login/login",
        "pages/role/role",
        "pages/family/family",
        "pages/privacy/privacy",
        "pages/agreement/agreement"
      ]
    },
    {
      "root": "subpkg-admin",
      "name": "admin",
      "pages": [
        "pages/admin/admin",
        "pages/questionManage/questionManage",
        "pages/stats/stats",
        "pages/reviewQueue/reviewQueue",
        "pages/unauthorized/unauthorized"
      ]
    }
  ],
  "preloadRule": {
    "pages/home/home": {
      "network": "all",
      "packages": ["learn", "user"]
    },
    "pages/mine/mine": {
      "network": "all",
      "packages": ["user"]
    }
  },
  "__usePrivacyCheck__": true,
  "window": {
    "navigationBarTitleText": "小升初冲刺打卡",
    "navigationBarTextStyle": "white",
    "navigationBarBackgroundColor": "#FF9F43",
    "backgroundColor": "#FFF8E7"
  },
  "tabBar": {
    "color": "#B2BEC3",
    "selectedColor": "#FF9F43",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "打卡",
        "iconPath": "images/checkin.png",
        "selectedIconPath": "images/checkin_active.png"
      },
      {
        "pagePath": "pages/calendar/calendar",
        "text": "日历",
        "iconPath": "images/stats.png",
        "selectedIconPath": "images/stats_active.png"
      },
      {
        "pagePath": "pages/rewards/rewards",
        "text": "商城",
        "iconPath": "images/profile.png",
        "selectedIconPath": "images/profile_active.png"
      },
      {
        "pagePath": "pages/mistakes/mistakes",
        "text": "错题本",
        "iconPath": "images/stats.png",
        "selectedIconPath": "images/stats_active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "images/profile.png",
        "selectedIconPath": "images/profile_active.png"
      }
    ]
  },
  "sitemapLocation": "sitemap.json"
}
