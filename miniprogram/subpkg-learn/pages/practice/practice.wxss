.practice-page {
  background: #FFF8E7;
  min-height: 100vh;
}

/* ===== 筛选面板 ===== */
.setting-panel { padding: 24rpx; }

.filter-group {
  margin-bottom: 24rpx;
}
.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.filter-label {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}
.picker-value {
  font-size: 28rpx;
  color: #FF9F43;
}

/* 题型标签 */
.type-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}
.type-tag {
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  background: #F0F0F0;
  font-size: 26rpx;
  color: #636E72;
  border: 2rpx solid transparent;
}
.type-tag-active {
  background: #FFF3E0;
  color: #FF9F43;
  border-color: #FF9F43;
}

.count-num {
  color: #FF9F43;
  font-weight: bold;
}

/* ===== 答题面板 ===== */
.answering-panel {
  position: relative;
}

/* 进度条 */
.question-progress {
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}
.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #636E72;
}
.back-link {
  color: #FF9F43;
}
.submit-early {
  color: #FF9F43;
  font-weight: 500;
}
.progress-bar-bg {
  height: 6rpx;
  background: #EEE;
  border-radius: 3rpx;
}
.progress-bar-fill {
  height: 100%;
  background: #FF9F43;
  border-radius: 3rpx;
  transition: width 0.3s;
}

/* 题目 Swiper */
.question-swiper {
  width: 100%;
}
.question-scroll {
  height: 100%;
  padding: 24rpx;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}
.q-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.q-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #2D3436;
}
.q-type-tag {
  font-size: 22rpx;
  background: #FFF3E0;
  color: #FF9F43;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.q-difficulty {
  font-size: 22rpx;
  background: #E8F5E9;
  color: #2ED573;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.q-stem {
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

/* ===== 选择题 ===== */
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E8E8E8;
  font-size: 28rpx;
  transition: all 0.2s;
}
.option-selected {
  border-color: #FF9F43;
  background: #FFF3E0;
}
.option-correct {
  border-color: #2ED573;
  background: #E8F5E9;
}
.option-wrong {
  border-color: #FF6B6B;
  background: #FFE0E0;
}
.opt-label {
  font-weight: bold;
  margin-right: 12rpx;
  color: #636E72;
  width: 36rpx;
}

/* ===== 判断题 ===== */
.judge-btns {
  display: flex;
  gap: 24rpx;
}
.judge-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E8E8E8;
  font-size: 30rpx;
  font-weight: bold;
  color: #636E72;
  transition: all 0.2s;
}
.judge-active {
  border-color: #FF9F43;
  background: #FFF3E0;
  color: #FF9F43;
}
.judge-active.judge-wrong {
  border-color: #FF6B6B;
  color: #FF6B6B;
  background: #FFE0E0;
}
.judge-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* ===== 填空题 ===== */
.blank-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.blank-input:focus {
  border-color: #FF9F43;
}

/* ===== 简答题 ===== */
.essay-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ===== 解析区 ===== */
.analysis {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}
.correct-badge {
  font-size: 28rpx;
  color: #2ED573;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.wrong-badge {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.correct-answer {
  font-size: 28rpx;
  color: #2ED573;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.analysis-text {
  font-size: 26rpx;
  color: #636E72;
  line-height: 1.6;
  margin-bottom: 8rpx;
}
.exam-point {
  font-size: 24rpx;
  color: #B2BEC3;
}

/* ===== 提交栏 ===== */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

/* ===== 结果底部 ===== */
.result-footer {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
}
.result-score {
  text-align: center;
  padding: 16rpx 0;
}
.score-label {
  display: block;
  font-size: 24rpx;
  color: #B2BEC3;
}
.score-num {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #FF9F43;
  margin: 8rpx 0;
}
.score-detail {
  display: block;
  font-size: 24rpx;
  color: #636E72;
}
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.result-actions .btn {
  flex: 1;
  margin: 0;
}
