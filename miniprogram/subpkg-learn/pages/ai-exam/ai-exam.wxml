<view class="container">
  <!-- 设置面板 -->
  <view class="settings" wx:if="{{!showQuestions}}">
    <view class="section-title">AI 出题中心</view>

    <view class="form-item">
      <text class="label">📚 学科</text>
      <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker">{{subjects[subjectIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">🎒 年级</text>
      <picker mode="selector" range="{{gradeList}}" value="{{gradeIndex}}" bindchange="onGradeChange">
        <view class="picker">{{gradeList[gradeIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">📗 教材版本</text>
      <picker mode="selector" range="{{textbooks}}" value="{{textbookIndex}}" bindchange="onTextbookChange">
        <view class="picker">{{textbooks[textbookIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">🎯 出题偏好</text>
      <picker mode="selector" range="{{preferences}}" value="{{prefIndex}}" bindchange="onPrefChange">
        <view class="picker">{{preferences[prefIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">🎯 知识点</text>
      <picker mode="selector" range="{{knowledgePoints}}" value="{{kpIndex}}" bindchange="onKPChange">
        <view class="picker">{{knowledgePoints[kpIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">📈 难度</text>
      <picker mode="selector" range="{{difficulties}}" value="{{diffIndex}}" bindchange="onDiffChange">
        <view class="picker">{{difficulties[diffIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">📝 题型</text>
      <picker mode="selector" range="{{questionTypes}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker">{{questionTypes[typeIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">🔢 数量</text>
      <slider min="1" max="10" value="{{count}}" bindchange="onCountChange" show-value block-size="20" />
    </view>

    <view class="form-item switch-item">
      <text class="label">🔄 自适应难度</text>
      <switch checked="{{autoDifficulty}}" bindchange="onAutoDiffChange" />
    </view>
    <view class="form-item switch-item">
      <text class="label">🎯 错题强化模式</text>
      <switch checked="{{useWrongBook}}" bindchange="onWrongBookChange" />
    </view>

    <button class="btn-primary" bindtap="generateQuestions" loading="{{generating}}">
      {{generating ? '正在生成...' : '开始出题'}}
    </button>
    <view class="tip">* 题目由AI生成，仅供参考，建议家长陪同使用</view>
  </view>

  <!-- 答题界面 -->
  <view class="questions" wx:if="{{showQuestions}}">
    <view class="header-bar">
      <text class="back-btn" bindtap="backToSettings">← 重新设置</text>
      <text class="progress-text" wx:if="{{generating}}">正在生成... {{streamCount}}/{{questions.length}}</text>
      <text class="progress-text" wx:else>{{currentIndex + 1}} / {{questions.length}}</text>
    </view>

    <swiper current="{{currentIndex}}" bindchange="onSwiperChange" class="question-swiper" duration="300">
      <swiper-item wx:for="{{questions}}" wx:key="id">
        <scroll-view scroll-y class="question-content">
          <view class="q-header">
            <text class="q-type">{{item.type}} · </text>
            <text class="q-diff">{{item.difficulty}}</text>
          </view>
          <view class="q-body">{{item.content}}</view>

          <!-- 选择题 -->
          <view class="options" wx:if="{{item.type === '选择题'}}">
            <view
              class="option {{userAnswers[item.id] === ['A','B','C','D','E','F'][optIdx] ? 'selected' : ''}} {{showResult && optIdx === item._correctOptIdx ? 'correct' : ''}} {{showResult && userAnswers[item.id] === ['A','B','C','D','E','F'][optIdx] && optIdx !== item._correctOptIdx ? 'wrong' : ''}}"
              wx:for="{{item.options}}"
              wx:for-item="optText"
              wx:for-index="optIdx"
              wx:key="optIdx"
              data-question-id="{{item.id}}"
              data-option="{{['A','B','C','D','E','F'][optIdx]}}"
              bindtap="selectOption"
            >
              <text class="opt-label">{{['A','B','C','D','E','F'][optIdx]}}.</text>
              <text class="opt-text">{{optText}}</text>
            </view>
          </view>

          <!-- 填空题 -->
          <view class="fill-blank" wx:if="{{item.type === '填空题'}}">
            <input
              class="blank-input"
              placeholder="请输入你的答案"
              value="{{userAnswers[item.id] || ''}}"
              data-question-id="{{item.id}}"
              bindinput="fillBlank"
              disabled="{{showResult}}"
            />
          </view>

          <!-- 应用题 -->
          <view class="fill-blank" wx:if="{{item.type === '应用题'}}">
            <textarea
              class="app-textarea"
              placeholder="请写下解题步骤和答案"
              value="{{userAnswers[item.id] || ''}}"
              data-question-id="{{item.id}}"
              bindinput="fillBlank"
              disabled="{{showResult}}"
            />
          </view>

          <!-- 听力填空 -->
          <view class="listening-section" wx:if="{{item.type === '听力填空'}}">
            <view class="listening-header">
              <text class="listening-icon">🔊</text>
              <text class="listening-title">英语听力</text>
            </view>
            <button class="btn-play" bindtap="playListening" data-question-id="{{item.id}}">
              {{listeningOpen[item.id] ? '⏹ 停止' : '🔊 播放听力'}}
            </button>
            <view class="listening-script" wx:if="{{listeningOpen[item.id] && item.listeningScript}}">
              <text class="script-label">📝 听力原文：</text>
              <text class="script-text">{{item.listeningScript}}</text>
            </view>
            <input
              class="blank-input"
              placeholder="请填写听到的单词"
              value="{{userAnswers[item.id] || ''}}"
              data-question-id="{{item.id}}"
              bindinput="fillBlank"
              disabled="{{showResult}}"
            />
          </view>

          <!-- 朗读题 -->
          <view class="speak-section" wx:if="{{item.type === '朗读题'}}">
            <view class="q-body">请朗读以下句子：</view>
            <view class="speak-text">{{item.content}}</view>
            <view wx:if="{{item.translation}}" class="speak-translation">📖 {{item.translation}}</view>
            <button class="btn-speak" bindtap="startRecord" wx:if="{{!recording && !audioFilePath}}">🎤 开始录音</button>
            <button class="btn-speak btn-speak-rec" bindtap="stopRecord" wx:if="{{recording}}">⏹ 停止录音</button>
            <view class="speak-actions" wx:if="{{audioFilePath && !recording}}">
              <button class="btn-speak btn-speak-play" bindtap="playRecord">🔊 回放</button>
              <button class="btn-speak btn-speak-submit" bindtap="submitSpeak">📊 提交评分</button>
            </view>
            <view class="speak-result" wx:if="{{speakScore !== null}}">
              <text class="speak-score">得分：{{speakScore}} 分</text>
              <text class="speak-suggestion">💡 {{speakSuggestion}}</text>
            </view>
          </view>

          <!-- 作文题 -->
          <view class="essay-section" wx:if="{{item.type === '作文题'}}">
            <view class="q-body">{{item.content}}</view>
            <textarea
              class="essay-input"
              placeholder="在此输入你的作文..."
              value="{{userAnswers[item.id] || ''}}"
              data-id="{{item.id}}"
              bindinput="onEssayInput"
              maxlength="500"
              disabled="{{showResult}}"
            />
          </view>

          <!-- 结果展示 -->
          <view class="analysis" wx:if="{{showResult}}">
            <view class="correct-badge" wx:if="{{item._isCorrect}}">✅ 回答正确：{{item.answer}}</view>
            <block wx:else>
              <view class="wrong-badge">❌ 你的答案：{{item._userText || '（未作答）'}}</view>
              <view class="correct-answer">✅ 正确答案：{{item.answer}}</view>
            </block>
            <view class="analysis-text" wx:if="{{item.analysis}}">📖 解析：{{item.analysis}}</view>
            <view class="exam-point" wx:if="{{item.examPoint}}">🎯 考察：{{item.examPoint}}</view>
          </view>
        </scroll-view>
      </swiper-item>
    </swiper>

    <!-- 流式生成中状态 -->
    <view class="stream-status" wx:if="{{generating && questions.length > 0}}">
      <text>AI 正在生成题目...</text>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-bar">
      <button class="btn-secondary" bindtap="prevQuestion" wx:if="{{currentIndex > 0}}">上一题</button>
      <button class="btn-secondary" bindtap="nextQuestion" wx:if="{{currentIndex < questions.length - 1 && !generating}}">下一题</button>
      <button class="btn-primary" bindtap="submitAnswers" wx:if="{{!showResult && !generating}}">提交批改</button>
      <button class="btn-primary" bindtap="redoQuestions" wx:if="{{showResult}}">重新做一遍</button>
      <button class="btn-secondary" bindtap="printQuestions" wx:if="{{showResult}}">🖨️ 打印试卷</button>
    </view>
  </view>
  <canvas type="2d" id="printCanvas" class="print-canvas"></canvas>
</view>
