.container {
  padding: 20rpx 30rpx;
  background: var(--bg-page);
  min-height: 100vh;
}
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: var(--color-primary-dark);
}
.form-item {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx var(--bg-overlay);
}
.label {
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}
.picker {
  color: var(--text-secondary);
  font-size: 28rpx;
}
slider {
  margin-top: 10rpx;
}
.btn-primary {
  background: var(--color-primary-dark);
  color: var(--text-on-primary);
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.btn-secondary {
  background: var(--border-color);
  color: var(--text-primary);
  border-radius: 40rpx;
  font-size: 28rpx;
}
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.switch-item .label { margin-bottom: 0; }
.stream-status {
  text-align: center;
  color: var(--color-primary-dark);
  font-size: 26rpx;
  padding: 10rpx 0;
}
.tip {
  text-align: center;
  color: var(--text-hint);
  font-size: 22rpx;
  margin-top: 16rpx;
}

/* 答题界面 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 0;
}
.back-btn {
  color: var(--color-primary-dark);
  font-size: 28rpx;
}
.progress-text {
  color: var(--text-secondary);
  font-weight: bold;
}
.question-swiper {
  height: 70vh;
}
.question-content {
  padding: 20rpx;
}
.q-header {
  margin-bottom: 20rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}
.q-type {
  color: var(--color-primary-dark);
  font-weight: bold;
}
.q-diff {
  background: var(--color-primary-light);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.q-body {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
  line-height: 1.6;
}
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option {
  background: white;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #EFEFEF;
  transition: 0.2s;
}
.option.selected {
  border-color: var(--color-primary-dark);
  background: var(--color-primary-light);
}
.option.correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.option.wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
}
.opt-label {
  font-weight: bold;
  margin-right: 12rpx;
  color: var(--color-primary-dark);
}
.opt-text {
  font-size: 28rpx;
}
.fill-blank {
  margin-top: 20rpx;
}
.blank-input, .app-textarea {
  border: 2rpx solid var(--border-light);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}
.app-textarea {
  height: 200rpx;
}
.analysis {
  margin-top: 30rpx;
  background: var(--bg-gray);
  border-radius: 16rpx;
  padding: 20rpx;
}
.correct-badge, .wrong-badge {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}
.correct-badge { color: var(--color-success); }
.wrong-badge { color: var(--color-error); }
.correct-answer {
  font-weight: bold;
  font-size: 28rpx;
  color: var(--color-success);
  margin-bottom: 8rpx;
}
.analysis-text, .exam-point {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
}
/* 听力填空 */
.listening-section {
  margin-top: 20rpx;
  background: var(--color-info-light);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid var(--color-info-light);
}
.listening-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.listening-icon { font-size: 36rpx; }
.listening-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-info);
}
.btn-play {
  background: var(--color-info);
  color: var(--text-on-primary);
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border: none;
  text-align: center;
}
.btn-play:active { opacity: 0.8; }
.listening-script {
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid var(--color-info);
}
.script-label {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 8rpx;
}
.script-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 朗读题 */
.speak-section { margin-top: 20rpx; }
.speak-text {
  font-size: 34rpx; font-weight: 700; color: var(--text-primary);
  padding: 24rpx; background: var(--color-info-light); border-radius: 16rpx;
  border-left: 6rpx solid var(--color-info); margin-bottom: 16rpx; line-height: 1.6;
}
.speak-translation {
  font-size: 24rpx; color: var(--text-hint); margin-bottom: 16rpx; padding: 0 8rpx;
}
.btn-speak {
  width: 100%; border-radius: 30rpx; font-size: 28rpx; padding: 20rpx 0;
  margin-bottom: 12rpx; text-align: center; color: var(--text-on-primary);
  background: linear-gradient(135deg, var(--color-info), var(--color-accent-light));
}
.btn-speak:active { opacity: 0.8; }
.btn-speak-rec { background: linear-gradient(135deg, var(--color-error), #E17055); }
.btn-speak-play { background: var(--color-success); }
.btn-speak-submit { background: linear-gradient(135deg, var(--color-primary), var(--color-primary)); }
.speak-actions { display: flex; gap: 16rpx; }
.speak-actions .btn-speak { flex: 1; padding: 16rpx 0; font-size: 26rpx; margin-bottom: 0; }
.speak-result {
  background: var(--bg-gray); border-radius: 16rpx; padding: 20rpx; margin-top: 12rpx;
}
.speak-score { font-size: 32rpx; font-weight: 700; color: var(--color-primary-dark); display: block; margin-bottom: 8rpx; }
.speak-suggestion { font-size: 26rpx; color: var(--text-secondary); display: block; }

/* 作文题 */
.essay-section { margin-top: 20rpx; }
.essay-input {
  width: 100%; height: 300rpx; border: 2rpx solid var(--border-light);
  border-radius: 16rpx; padding: 20rpx; font-size: 28rpx;
  box-sizing: border-box; line-height: 1.6; margin-top: 16rpx;
}

.print-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 2000px; }
.bottom-bar {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  gap: 20rpx;
}
.bottom-bar button {
  flex: 1;
  margin: 0;
}
