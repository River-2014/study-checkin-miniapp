.badges-page {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #FFF8E7;
  min-height: 100vh;
}

/* 统计头 */
.badge-header {
  text-align: center;
  padding: 32rpx 0 16rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2D3436;
  display: block;
}
.header-sub {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-top: 8rpx;
  display: block;
}

/* 进度条 */
.progress-bar-bg {
  width: 100%;
  height: 12rpx;
  background: #EEE;
  border-radius: 6rpx;
  margin: 16rpx 0 32rpx;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9F43, #FDCB6E);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 徽章网格 */
.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: space-between;
}
.badge-grid::after {
  content: '';
  flex: 1;
}

/* 徽章卡片 */
.badge-card {
  width: calc(50% - 8rpx);
  padding: 28rpx 16rpx;
  border-radius: 20rpx;
  text-align: center;
  box-sizing: border-box;
  transition: all 0.3s ease;
}
.badge-earned {
  background: linear-gradient(135deg, #FFF3E0, #FFF8E1);
  box-shadow: 0 4rpx 16rpx rgba(255, 159, 67, 0.15);
}
.badge-locked {
  background: #F5F5F5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 图标 */
.badge-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
.badge-earned .badge-icon-wrap {
  background: rgba(255, 159, 67, 0.1);
}
.badge-locked .badge-icon-wrap {
  background: #E8E8E8;
}
.badge-icon {
  font-size: 44rpx;
}

/* 文字 */
.badge-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2D3436;
  display: block;
  margin-bottom: 4rpx;
}
.badge-locked .badge-title {
  color: #B2BEC3;
}
.badge-desc {
  font-size: 22rpx;
  color: #636E72;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.4;
}
.badge-locked .badge-desc {
  color: #B2BEC3;
  font-size: 20rpx;
}

/* 标签 */
.badge-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.earned-tag {
  background: #2ED573;
  color: #FFF;
}
.locked-tag {
  background: #DFE6E9;
  color: #B2BEC3;
}

/* 底部 */
.badge-footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 24rpx;
  color: #B2BEC3;
}
