.wr-page { padding: 24rpx; background: #F5F6FA; min-height: 100vh; }
.wr-header { text-align: center; margin-bottom: 24rpx; }
.wr-title { font-size: 36rpx; font-weight: bold; color: #2D3436; display: block; }
.wr-date { font-size: 24rpx; color: #B2BEC3; }
.wr-stats { display: flex; background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.wr-stat { flex: 1; text-align: center; }
.wr-stat-num { font-size: 36rpx; font-weight: bold; color: #FF9F43; display: block; }
.wr-stat-label { font-size: 22rpx; color: #B2BEC3; }
.wr-highlight { background: linear-gradient(135deg, #6C5CE7, #A29BFE); color: #fff; border-radius: 16rpx; padding: 24rpx; text-align: center; font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; }
.wr-card { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; }
.wr-card-title { font-size: 26rpx; font-weight: bold; color: #2D3436; margin-bottom: 12rpx; }
.wr-meta { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 24rpx; color: #636E72; }
