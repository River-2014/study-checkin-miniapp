.wr-page { padding: 24rpx; background: var(--bg-page); min-height: 100vh; }
.wr-header { text-align: center; margin-bottom: 24rpx; }
.wr-title { font-size: 36rpx; font-weight: bold; color: var(--text-primary); display: block; }
.wr-date { font-size: 24rpx; color: var(--text-hint); }
.wr-stats { display: flex; background: var(--bg-card); border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.wr-stat { flex: 1; text-align: center; }
.wr-stat-num { font-size: 36rpx; font-weight: bold; color: var(--color-primary); display: block; }
.wr-stat-label { font-size: 22rpx; color: var(--text-hint); }
.wr-highlight { background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light)); color: var(--text-on-primary); border-radius: 16rpx; padding: 24rpx; text-align: center; font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; }
.wr-card-title { font-size: 26rpx; font-weight: bold; color: var(--text-primary); margin-bottom: 12rpx; }
.wr-meta { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 24rpx; color: var(--text-secondary); }
