.pomo-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx; background: var(--bg-page); }
.pomo-circle { width: 360rpx; height: 360rpx; border-radius: 50%; border: 8rpx solid var(--color-primary); display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 40rpx; background: var(--bg-card); }
.pomo-anim { animation: pomoPulse 2s infinite; }
@keyframes pomoPulse { 0%,100% { box-shadow: 0 0 0 0 rgba(255,159,67,0.3); } 50% { box-shadow: 0 0 0 30rpx rgba(255,159,67,0); } }
.pomo-time { font-size: 72rpx; font-weight: bold; color: var(--text-primary); }
.pomo-label { font-size: 26rpx; color: var(--text-secondary); margin-top: 8rpx; }
.pomo-stats { display: flex; gap: 40rpx; margin-bottom: 32rpx; }
.pomo-stat { text-align: center; }
.pomo-stat-num { font-size: 40rpx; font-weight: bold; color: var(--color-primary); display: block; }
.pomo-stat-label { font-size: 22rpx; color: var(--text-hint); }
.pomo-actions { display: flex; gap: 20rpx; margin-bottom: 40rpx; }
.pomo-btn { padding: 20rpx 50rpx; border-radius: 40rpx; font-size: 30rpx; font-weight: bold; }
.pomo-btn.start { background: var(--color-primary); color: var(--text-on-primary); }
.pomo-btn.pause { background: var(--color-primary); color: var(--text-on-primary); }
.pomo-btn.reset { background: var(--border-color); color: var(--text-secondary); }
.pomo-settings { width: 100%; background: var(--bg-card); border-radius: 16rpx; padding: 24rpx; }
.setting-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; font-size: 28rpx; }
.setting-row input { width: 120rpx; text-align: center; border: 1px solid #ddd; border-radius: 8rpx; padding: 8rpx; }
