.pomo-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx; background: #F5F6FA; }
.pomo-circle { width: 360rpx; height: 360rpx; border-radius: 50%; border: 8rpx solid #FF9F43; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 40rpx; background: #fff; }
.pomo-anim { animation: pomoPulse 2s infinite; }
@keyframes pomoPulse { 0%,100% { box-shadow: 0 0 0 0 rgba(255,159,67,0.3); } 50% { box-shadow: 0 0 0 30rpx rgba(255,159,67,0); } }
.pomo-time { font-size: 72rpx; font-weight: bold; color: #2D3436; }
.pomo-label { font-size: 26rpx; color: #636E72; margin-top: 8rpx; }
.pomo-stats { display: flex; gap: 40rpx; margin-bottom: 32rpx; }
.pomo-stat { text-align: center; }
.pomo-stat-num { font-size: 40rpx; font-weight: bold; color: #FF9F43; display: block; }
.pomo-stat-label { font-size: 22rpx; color: #B2BEC3; }
.pomo-actions { display: flex; gap: 20rpx; margin-bottom: 40rpx; }
.pomo-btn { padding: 20rpx 50rpx; border-radius: 40rpx; font-size: 30rpx; font-weight: bold; }
.pomo-btn.start { background: #FF9F43; color: #fff; }
.pomo-btn.pause { background: #F39C12; color: #fff; }
.pomo-btn.reset { background: #F0F0F0; color: #636E72; }
.pomo-settings { width: 100%; background: #fff; border-radius: 16rpx; padding: 24rpx; }
.setting-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; font-size: 28rpx; }
.setting-row input { width: 120rpx; text-align: center; border: 1px solid #ddd; border-radius: 8rpx; padding: 8rpx; }
