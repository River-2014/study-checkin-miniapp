<view class="pomo-page">
  <view class="pomo-circle {{running ? 'pomo-anim' : ''}}" style="border-color: {{isBreak ? '#00B894' : '#FF9F43'}}">
    <text class="pomo-time">{{minutes < 10 ? '0'+minutes : minutes}}:{{seconds < 10 ? '0'+seconds : seconds}}</text>
    <text class="pomo-label">{{isBreak ? '休息中 ☕' : '专注中 📖'}}</text>
  </view>

  <view class="pomo-stats">
    <view class="pomo-stat">
      <text class="pomo-stat-num">{{completed}}</text>
      <text class="pomo-stat-label">今日番茄</text>
    </view>
    <view class="pomo-stat">
      <text class="pomo-stat-num">{{totalCompleted}}</text>
      <text class="pomo-stat-label">累计番茄</text>
    </view>
    <view class="pomo-stat">
      <text class="pomo-stat-num">{{totalMinutes}}</text>
      <text class="pomo-stat-label">累计分钟</text>
    </view>
  </view>

  <view class="pomo-actions">
    <button wx:if="{{!running}}" class="pomo-btn start" bindtap="start">开始</button>
    <button wx:if="{{running}}" class="pomo-btn pause" bindtap="pause">{{running ? '暂停' : '继续'}}</button>
    <button class="pomo-btn reset" bindtap="reset">重置</button>
  </view>

  <view class="pomo-settings">
    <view class="setting-row">
      <text>工作时长 (分钟)</text>
      <input type="number" value="{{workMinutes}}" bindinput="onWorkChange" />
    </view>
    <view class="setting-row">
      <text>休息时长 (分钟)</text>
      <input type="number" value="{{breakMinutes}}" bindinput="onBreakChange" />
    </view>
  </view>
</view>
