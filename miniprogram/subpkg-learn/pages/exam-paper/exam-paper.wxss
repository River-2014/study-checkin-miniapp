.paper-page {
  background: var(--bg-page);
  min-height: 100vh;
}

/* ===== 模式选择 ===== */
.mode-selector {
  display: flex;
  background: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx var(--bg-overlay);
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.mode-active {
  color: var(--text-on-primary);
  background: linear-gradient(135deg, var(--color-primary), var(--color-error));
}

/* ===== 试卷筛选 ===== */
.paper-filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.paper-filter .picker-link {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}
.filter-search {
  flex: 1; min-width: 160rpx; height: 60rpx;
  border: 2rpx solid var(--border-light); border-radius: 10rpx;
  padding: 0 12rpx; font-size: 26rpx;
  box-sizing: border-box;
}

/* ===== 试卷列表 ===== */
.paper-list-loading {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-hint);
  font-size: 28rpx;
}
.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.empty-hint text:first-child {
  font-size: 30rpx; color: var(--text-hint);
}
.empty-sub {
  font-size: 24rpx !important;
  color: #C8C8C8 !important;
}

.paper-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx var(--bg-overlay);
  border-left: 6rpx solid var(--color-primary);
}
.paper-card-head {
  margin-bottom: 10rpx;
}
.paper-title {
  font-size: 28rpx; font-weight: 600; color: var(--text-primary);
  line-height: 1.4;
}
.paper-card-meta {
  display: flex; flex-wrap: wrap; gap: 8rpx 16rpx;
  font-size: 24rpx; color: var(--text-secondary);
  margin-bottom: 8rpx;
}
.paper-card-tap {
  text-align: right;
  font-size: 24rpx; color: var(--color-primary); font-weight: 500;
}

/* 分页 */
.pagination {
  display: flex; align-items: center;
  justify-content: center; gap: 16rpx;
  margin-top: 20rpx;
}
.page-info {
  font-size: 26rpx; color: var(--text-secondary);
}

/* ===== 设置面板 ===== */
.setting-panel { padding: 24rpx; }

.filter-group {
  margin-bottom: 24rpx;
}
.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}
.filter-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.picker-value {
  font-size: 28rpx;
  color: var(--color-primary);
}

/* 题型分布 */
.type-dist-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}
.dist-item {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  background: var(--border-color);
  text-align: center;
  border: 2rpx solid transparent;
}
.dist-active {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}
.dist-type {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.dist-active .dist-type {
  color: var(--color-primary);
}
.dist-count {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* ===== 答题顶部栏 ===== */
.exam-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
  font-size: 26rpx;
}
.exam-title {
  color: var(--text-primary);
  font-weight: 500;
}
.countdown {
  color: var(--color-primary);
  font-weight: bold;
}
.countdown-warn {
  color: var(--color-error);
  animation: blink 1s infinite;
}
@keyframes blink {
  50% { opacity: 0.5; }
}

/* 进度 */
.question-progress {
  padding: 12rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
}
.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.submit-early {
  color: var(--color-primary);
  font-weight: 500;
}
.progress-bar-bg {
  height: 4rpx;
  background: var(--border-light);
  border-radius: 2rpx;
}
.progress-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2rpx;
  transition: width 0.3s;
}

/* Swiper */
.question-swiper {
  width: 100%;
  height: calc(100vh - 340rpx) !important;
}
.question-scroll {
  height: 100%;
  padding: 24rpx;
}
.question-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}
.q-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.q-num {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}
.q-type-tag {
  font-size: 22rpx;
  background: var(--color-primary-light);
  color: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.q-pts {
  font-size: 22rpx;
  color: var(--text-hint);
}
.q-stem {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 24rpx;
}

/* 选择题 */
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--border-light);
  font-size: 28rpx;
  transition: all 0.2s;
}
.option-selected {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}
.option-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.option-wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
}
.opt-label {
  font-weight: bold;
  margin-right: 12rpx;
  color: var(--text-secondary);
  width: 36rpx;
}

/* 判断题 */
.judge-btns {
  display: flex;
  gap: 24rpx;
}
.judge-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--border-light);
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.judge-active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
  color: var(--color-primary);
}
.judge-active.judge-wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
  color: var(--color-error);
}

/* 填空 */
.blank-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--border-light);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 简答 */
.essay-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid var(--border-light);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 解析 */
.analysis {
  margin-top: 24rpx;
  padding: 20rpx;
  background: var(--bg-gray-light);
  border-radius: 12rpx;
}
.correct-badge {
  font-size: 28rpx;
  color: var(--color-success);
  font-weight: bold;
  margin-bottom: 8rpx;
}
.wrong-badge {
  font-size: 28rpx;
  color: var(--color-error);
  font-weight: bold;
  margin-bottom: 8rpx;
}
.correct-answer {
  font-size: 28rpx;
  color: var(--color-success);
  font-weight: bold;
  margin-bottom: 8rpx;
}
.analysis-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -2rpx 10rpx var(--bg-overlay);
}

/* ===== 成绩报告 ===== */
.result-panel {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}
.score-card {
  text-align: center;
  padding: 40rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-warning));
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  color: var(--text-on-primary);
}
.score-big {
  font-size: 80rpx;
  font-weight: bold;
  display: block;
}
.score-total {
  font-size: 32rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 8rpx;
}
.score-rate {
  font-size: 26rpx;
  opacity: 0.7;
  display: block;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 10rpx 0 16rpx;
}
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.result-actions .btn {
  flex: 1;
  margin: 0;
}
