.lb-page { min-height: 100vh; background: var(--bg-page); padding: 20rpx; }
.lb-optin { text-align: center; padding: 100rpx 40rpx; }
.lb-optin-title { font-size: var(--font-lg); font-weight: bold; color: var(--text-primary); display: block; margin-bottom: 12rpx; }
.lb-optin-desc { font-size: 24rpx; color: var(--text-hint); display: block; margin-bottom: 40rpx; }
.lb-optin-btn { background: linear-gradient(135deg, var(--color-primary), var(--color-primary)); color: var(--text-on-primary); border-radius: 40rpx; width: 400rpx; }

.lb-list { background: var(--bg-card); border-radius: 16rpx; overflow: hidden; }
.lb-item { display: flex; align-items: center; padding: 20rpx 24rpx; border-bottom: 2rpx solid #F8F8F8; }
.lb-item:last-child { border-bottom: none; }
.lb-item.top-1 { background: linear-gradient(90deg, var(--color-warning-light), var(--bg-card)); }
.lb-item.top-2 { background: linear-gradient(90deg, var(--bg-gray), var(--bg-card)); }
.lb-item.top-3 { background: linear-gradient(90deg, var(--color-primary-light), var(--bg-card)); }
.lb-rank { font-size: var(--font-xl); width: 60rpx; text-align: center; }
.lb-info { flex: 1; display: flex; flex-direction: column; }
.lb-name { font-size: var(--font-md); color: var(--text-primary); font-weight: 500; }
.lb-sub { font-size: var(--font-xs); color: var(--text-hint); }
.lb-value { text-align: right; }
.lb-num { font-size: 36rpx; font-weight: bold; color: var(--color-primary); }
.lb-unit { font-size: 24rpx; color: var(--text-hint); }
.lb-empty { text-align: center; padding: 80rpx; color: var(--text-hint); font-size: var(--font-sm); }
.lb-footer { text-align: center; padding: 30rpx; }
