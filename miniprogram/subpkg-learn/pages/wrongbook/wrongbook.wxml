<view class="container">
  <view class="section-title">📖 错题本</view>

  <view class="toolbar">
    <text class="count-info">共 {{wrongList.length}} 道错题</text>
    <button class="btn-export" bindtap="exportWrongBook" wx:if="{{wrongList.length > 0}}">🖨️ 导出为图片</button>
  </view>

  <block wx:for="{{wrongList}}" wx:key="id">
    <view class="card card--compact">
      <view class="card-header">
        <text class="subject">{{item.subject}} · {{item.knowledge}}</text>
        <text class="diff">{{item.difficulty}}</text>
      </view>
      <view class="q-type">{{item.type}}</view>
      <view class="q-content">{{item.content}}</view>
      <view class="options" wx:if="{{item.options && item.options.length > 0}}">
        <view class="opt-item" wx:for="{{item.options}}" wx:for-index="i" wx:key="i">
          <text class="opt-label">{{['A','B','C','D'][i]}}.</text>
          <text>{{item}}</text>
        </view>
      </view>
      <view class="answer-section" wx:if="{{item.showAnswer}}">
        <text class="answer-label">✅ 正确答案：{{item.answer}}</text>
        <text class="analysis-text">📖 {{item.analysis}}</text>
        <text class="exam-point">🎯 考察：{{item.examPoint}}</text>
      </view>
      <view class="actions">
        <button size="mini" bindtap="toggleAnswer" data-id="{{item.id}}">
          {{item.showAnswer ? '隐藏解析' : '查看解析'}}
        </button>
        <button size="mini" class="btn-retry" bindtap="retrySimilar" data-item="{{item}}">同类题再练</button>
        <button size="mini" class="btn-mastered" bindtap="removeWrong" data-id="{{item.id}}">已掌握</button>
      </view>
    </view>
  </block>

  <view wx:if="{{wrongList.length === 0}}" class="empty">
    <text class="empty-icon">🎉</text>
    <text>暂无错题，继续保持！</text>
  </view>

  <canvas type="2d" id="exportCanvas" class="export-canvas"></canvas>
</view>
