.container { padding: 20rpx 30rpx; background: var(--bg-page); min-height: 100vh; }
.section-title { font-size: 36rpx; font-weight: bold; margin-bottom: 10rpx; color: var(--color-primary-dark); }
.count-info { font-size: 24rpx; color: var(--text-hint); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.subject { font-size: 24rpx; font-weight: 600; color: var(--color-primary-dark); }
.diff {
  font-size: 20rpx; background: var(--color-primary-light); padding: 4rpx 14rpx; border-radius: 8rpx; color: #E17055;
}
.q-type { font-size: 22rpx; color: var(--text-hint); margin-bottom: 8rpx; }
.q-content { font-size: 30rpx; font-weight: 500; line-height: 1.6; margin-bottom: 16rpx; color: var(--text-primary); }
.options { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 16rpx; }
.opt-item { font-size: 26rpx; color: var(--text-secondary); }
.opt-label { font-weight: bold; color: var(--color-primary-dark); margin-right: 8rpx; }
.answer-section { background: var(--bg-gray); border-radius: 12rpx; padding: 16rpx; margin-bottom: 16rpx; }
.answer-label { font-weight: 600; color: var(--color-success); font-size: 26rpx; display: block; margin-bottom: 8rpx; }
.analysis-text, .exam-point { font-size: 24rpx; color: var(--text-secondary); line-height: 1.5; display: block; margin-top: 6rpx; }
.actions { display: flex; gap: 16rpx; }
.actions button { flex: 1; font-size: 24rpx; padding: 10rpx 0; border-radius: 12rpx; }
.btn-retry { background: var(--color-primary-dark); color: var(--text-on-primary); }
.btn-mastered { background: var(--color-success); color: var(--text-on-primary); }
.toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.btn-export { font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 12rpx; background: var(--color-accent); color: var(--text-on-primary); }
.export-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 1500px; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; color: var(--text-hint); font-size: 28rpx; }
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
