/* ===== CSS 变量体系 ===== */
page {
  /* ---- 品牌色 ---- */
  --color-primary: #FF9F43;
  --color-primary-dark: #E8831A;
  --color-primary-light: #FFF3E0;

  /* ---- 功能色 ---- */
  --color-success: #2ED573;
  --color-success-light: #E8F5E9;
  --color-error: #FF6B6B;
  --color-error-light: #FFE0E0;
  --color-warning: #FDCB6E;
  --color-warning-light: #FFF8E1;
  --color-info: #54A0FF;
  --color-info-light: #F0F7FF;
  --color-accent: #6C5CE7;
  --color-accent-light: #A29BFE;

  /* ---- 背景色 ---- */
  --bg-page: #FFF8E7;
  --bg-card: #FFFFFF;
  --bg-gray: #F8F9FA;
  --bg-gray-light: #FAFAFA;
  --bg-overlay: rgba(0, 0, 0, 0.04);
  --bg-mask: rgba(0, 0, 0, 0.5);

  /* ---- 文字色 ---- */
  --text-primary: #2D3436;
  --text-secondary: #636E72;
  --text-hint: #B2BEC3;
  --text-placeholder: #999999;
  --text-on-primary: #FFFFFF;

  /* ---- 边框色 ---- */
  --border-color: #F0F0F0;
  --border-light: #E8E8E8;

  /* ---- 渐变 ---- */
  --gradient-primary: linear-gradient(135deg, #FF9F43, #E8831A);
  --gradient-success: linear-gradient(135deg, #2ED573, #7BED9F);
  --gradient-error: linear-gradient(135deg, #FF6B6B, #EE5A24);

  /* ---- 阴影 ---- */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);

  /* ---- 圆角 ---- */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 50%;

  /* ---- 间距 ---- */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* ---- 字号 ---- */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* ---- 字重 ---- */
  --weight-normal: 400;
  --weight-medium: 500;
  --weight-semibold: 600;
  --weight-bold: 700;
}

/* ===== 全局基础 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background-color: var(--bg-page);
  color: var(--text-primary);
  font-size: var(--font-md);
  box-sizing: border-box;
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-md) 24rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: var(--shadow-md);
}

/* ===== 通用按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  font-weight: var(--weight-semibold);
}

.btn-primary {
  background: var(--gradient-primary);
  color: var(--text-on-primary);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-success {
  background: var(--gradient-success);
  color: var(--text-on-primary);
}

.btn-danger {
  background: var(--gradient-error);
  color: var(--text-on-primary);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: var(--font-sm);
  border-radius: var(--radius-md);
}

.btn-block {
  width: 100%;
  padding: 26rpx 0;
}

/* ===== 页面标题 ===== */
.page-title {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  padding: 20rpx 24rpx 10rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--text-hint);
  font-size: var(--font-md);
}

.empty-state .emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* ===== 卡片变体 ===== */
.card--compact { border-radius: var(--radius-lg); }
.card--full    { margin: 0; border-radius: 0; box-shadow: none; }

/* ===== 分隔线 ===== */
.divider {
  height: 2rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  font-weight: var(--weight-medium);
}

.tag-primary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-success {
  background: var(--color-success-light);
  color: var(--color-success);
}

.tag-error {
  background: var(--color-error-light);
  color: var(--color-error);
}

/* ===== 学科标签 ===== */
.tag-chinese  { background: var(--color-primary); color: var(--text-on-primary); }
.tag-math     { background: var(--color-success); color: var(--text-on-primary); }
.tag-english  { background: var(--color-info); color: var(--text-on-primary); }
.tag-general  { background: var(--color-accent-light); color: var(--text-primary); }
.tag-sport    { background: var(--color-error); color: var(--text-on-primary); }
.tag-life     { background: var(--color-warning); color: var(--text-primary); }

/* ===== 骨架屏 ===== */
.sk-shimmer {
  background: linear-gradient(90deg, var(--border-color) 25%, var(--border-light) 50%, var(--border-color) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.skeleton--text  { height: 28rpx; border-radius: var(--radius-sm); }
.skeleton--title { height: 40rpx; border-radius: var(--radius-sm); width: 40%; }
.skeleton--card  { height: 120rpx; border-radius: var(--radius-lg); }
.skeleton--row   { height: 64rpx; border-radius: var(--radius-md); margin-bottom: 16rpx; }
.skeleton--avatar { height: 80rpx; width: 80rpx; border-radius: 50%; }

/* ===== 安全区适配 ===== */
.safe-bottom {
  padding-bottom: 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
