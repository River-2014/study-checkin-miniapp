/* ===== 全局样式 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background-color: #FFF8E7;
  color: #2D3436;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ===== CSS变量 ===== */
page {
  --theme-orange: #FF9F43;
  --theme-orange-dark: #E8831A;
  --theme-green: #2ED573;
  --theme-green-light: #7BED9F;
  --bg-cream: #FFF8E7;
  --card-white: #FFFFFF;
  --text-dark: #2D3436;
  --text-gray: #636E72;
  --text-light: #B2BEC3;
  --shadow-card: 0 4rpx 20rpx rgba(0,0,0,0.08);
  --radius-card: 24rpx;
  --radius-btn: 16rpx;
  --radius-badge: 12rpx;
}

/* ===== 通用卡片 ===== */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

/* ===== 通用按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #FF9F43, #E8831A);
  color: white;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-success {
  background: linear-gradient(135deg, #2ED573, #7BED9F);
  color: white;
}

.btn-danger {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
  color: white;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.btn-block {
  width: 100%;
  padding: 26rpx 0;
}

/* ===== 页面标题 ===== */
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  padding: 20rpx 24rpx 10rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #B2BEC3;
  font-size: 28rpx;
}

.empty-state .emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* ===== 分隔线 ===== */
.divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 20rpx 0;
}

/* ===== 安全区适配 ===== */
.safe-bottom {
  padding-bottom: 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
