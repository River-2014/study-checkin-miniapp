/* ===== 密码页面 ===== */
.password-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 0;
  min-height: 100vh;
  background: var(--bg-card);
}

.pwd-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.pwd-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.pwd-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ===== 圆点行 ===== */
.dot-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 30rpx;
}

.pwd-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid #DFE6E9;
  background: var(--bg-gray);
  transition: all 0.2s;
}

.pwd-dot.filled {
  background: var(--color-primary);
  border-color: var(--color-primary);
  transform: scale(1.15);
}

/* ===== 错误提示 ===== */
.error-text {
  font-size: 24rpx;
  color: var(--color-error);
  margin-bottom: 20rpx;
  display: block;
}

/* ===== 数字键盘 ===== */
.keypad {
  display: flex;
  flex-wrap: wrap;
  width: 540rpx;
  margin-top: 20rpx;
}

.key-btn {
  width: 180rpx;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 500;
  color: var(--text-primary);
  border-radius: 16rpx;
}

.key-btn:active {
  background: var(--border-color);
}

.key-btn.key-empty {
  visibility: hidden;
}

/* ===== 忘记密码 ===== */
.pwd-footer {
  margin-top: 60rpx;
}

.forgot-link {
  font-size: 26rpx;
  color: var(--text-hint);
  text-decoration: underline;
}
