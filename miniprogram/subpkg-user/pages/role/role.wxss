.container {
  padding: 80rpx 40rpx;
  background: linear-gradient(180deg, var(--bg-page), var(--bg-card));
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 60rpx;
}
.role-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx var(--bg-overlay);
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.2s;
}
.role-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.role-emoji {
  font-size: 64rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.role-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.role-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.role-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}
.role-arrow {
  font-size: 40rpx;
  color: var(--border-light);
}

/* 年级选择 */
.grade-section {
  margin-top: 40rpx;
  text-align: center;
}
.grade-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}
.grade-picker {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.grade-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
}
.grade-arrow {
  font-size: var(--font-xs);
  color: var(--text-hint);
}
.grade-hint {
  font-size: var(--font-xs);
  color: var(--text-hint);
  display: block;
  margin-top: 12rpx;
}
