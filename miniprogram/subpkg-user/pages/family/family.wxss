.family-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 30rpx;
}
.family-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx var(--bg-overlay);
}
.family-section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}
.family-code-area {
  text-align: center;
  padding: 30rpx;
  background: var(--bg-page);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.family-code-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}
.family-code-value {
  font-size: var(--font-xxl);
  font-weight: bold;
  color: var(--color-primary);
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 12rpx;
}
.family-code-hint {
  font-size: var(--font-xs);
  color: var(--text-hint);
  display: block;
}
.btn-primary {
  background: var(--color-primary);
  color: var(--text-on-primary);
  font-size: var(--font-md);
  padding: 20rpx 0;
  border-radius: 50rpx;
  width: 100%;
  text-align: center;
}
.btn-outline {
  background: var(--bg-card);
  color: var(--color-primary);
  font-size: var(--font-md);
  padding: 20rpx 0;
  border-radius: 50rpx;
  width: 100%;
  text-align: center;
  border: 2rpx solid var(--color-primary);
  margin-top: 20rpx;
}
.btn-outline[disabled] {
  opacity: 0.4;
}
.family-divider {
  height: 2rpx;
  background: var(--border-color);
  margin: 30rpx 0;
}
.family-empty {
  text-align: center;
  color: var(--text-hint);
  font-size: var(--font-sm);
  padding: 40rpx 0;
}
.family-member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F8F8F8;
}
.family-member-item:last-child {
  border-bottom: none;
}
.member-avatar {
  font-size: var(--font-xxl);
  margin-right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.member-info {
  flex: 1;
}
.member-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}
.family-code-input {
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: var(--font-md);
  text-align: center;
  letter-spacing: 12rpx;
}

/* ===== 契约模板 ===== */
.contract-tpl-list { display: flex; flex-direction: column; gap: 12rpx; }
.contract-tpl-item {
  display: flex; align-items: center; padding: 16rpx 20rpx;
  background: var(--bg-gray); border-radius: 12rpx;
}
.contract-tpl-item:active { background: var(--color-accent-light); }
.tpl-left { flex: 1; }
.tpl-title { font-size: var(--font-md); color: var(--text-primary); font-weight: 500; display: block; }
.tpl-desc { font-size: var(--font-xs); color: var(--text-hint); }
.tpl-arrow { font-size: var(--font-lg); color: var(--color-primary); font-weight: bold; }

/* ===== 契约列表项 ===== */
.contract-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F8F8F8;
}
.contract-item:last-child { border-bottom: none; }
.ct-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.ct-title { font-size: var(--font-md); font-weight: 500; color: var(--text-primary); }
.ct-status { font-size: var(--font-xs); padding: 4rpx 12rpx; border-radius: 12rpx; }
.ct-pending { background: var(--color-warning-light); color: var(--color-primary-dark); }
.ct-active { background: var(--color-success-light); color: var(--color-success); }
.ct-completed { background: var(--color-accent-light); color: var(--color-accent); }
.ct-rejected { background: var(--color-error-light); color: var(--color-error); }
.ct-body { display: flex; justify-content: space-between; font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; }
.ct-bar { height: 8rpx; background: var(--border-color); border-radius: 4rpx; margin-bottom: 12rpx; }
.ct-bar-fill { height: 100%; background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light)); border-radius: 4rpx; transition: width 0.5s; }
.ct-actions { display: flex; gap: 12rpx; }
.redeem-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 2rpx solid #F8F8F8; }
.redeem-item:last-child { border-bottom: none; }
.redeem-info { flex: 1; }
.redeem-name { font-size: var(--font-sm); color: var(--text-primary); font-weight: 500; display: block; }
.redeem-cost { font-size: var(--font-xs); color: var(--text-hint); }
.redeem-actions { display: flex; gap: 12rpx; }
