page { background: #FFF8E7; }

.page { padding: 20rpx 0 60rpx; }

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 10rpx;
}

.update-date {
  font-size: 24rpx;
  color: #B2BEC3;
  display: block;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF9F43;
  display: block;
  margin: 30rpx 0 14rpx;
}

.content {
  font-size: 28rpx;
  color: #636E72;
  line-height: 1.7;
  display: block;
  white-space: pre-line;
}
