page { background: var(--bg-page); }

.page { padding: 20rpx 0 60rpx; }

.card {
  margin: 0 30rpx;
  padding: 40rpx 30rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.update-date, .subtitle {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 4rpx;
}

.subtitle {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin: 34rpx 0 16rpx;
}

.content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.75;
  display: block;
  margin-bottom: 8rpx;
}
