.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--bg-page) 0%, var(--color-primary-light) 100%);
  padding: 30rpx;
}
.login-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 8rpx 30rpx var(--bg-overlay);
}
.login-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}
.login-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}
.btn-primary {
  background: var(--color-primary);
  color: var(--text-on-primary);
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
  width: 100%;
}
.btn-primary:active {
  background: var(--color-primary-dark);
}
.login-agreement {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 30rpx;
}
.agreement-link {
  color: var(--color-primary);
}
