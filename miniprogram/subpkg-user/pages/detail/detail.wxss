.container { padding: 20rpx 24rpx; background: var(--bg-page); min-height: 100vh; }
.detail-list { background: var(--bg-card); border-radius: 20rpx; padding: 8rpx 24rpx; }
.mini-chart { background: var(--bg-card); border-radius: 16rpx; padding: 16rpx; margin-bottom: 16rpx; }
.mini-chart-title { font-size: var(--font-sm); font-weight: bold; color: var(--text-primary); margin-bottom: 10rpx; display: block; }
.date-title { font-size: var(--font-md); font-weight: 700; color: var(--color-primary); margin: 20rpx 0 12rpx; }
.log-item { display: flex; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.log-item:last-child { border-bottom: none; }
.log-icon { font-size: var(--font-lg); margin-right: 16rpx; }
.log-time { font-size: var(--font-xs); color: var(--text-hint); width: 140rpx; flex-shrink: 0; }
.log-desc { flex: 1; font-size: var(--font-md); color: var(--text-primary); }
.log-points { font-weight: 700; font-size: var(--font-md); margin-left: 12rpx; white-space: nowrap; }
.log-points.earn { color: var(--color-success); }
.log-points.spend { color: var(--color-error); }
.empty { text-align: center; color: var(--text-hint); padding: 60rpx 0; font-size: var(--font-md); }
.chart-container {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
  margin-bottom: 8rpx;
}
.rate-chart {
  width: 100%;
  height: 320rpx;
}
.radar-container {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
  margin-bottom: 8rpx;
}
.radar-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.radar-canvas {
  width: 100%;
  height: 400rpx;
}
.ai-record-info { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; margin-left: 12rpx; flex-shrink: 0; }
.ai-record-text { font-size: var(--font-xs); color: var(--text-hint); }
.ai-record-score { font-weight: 700; font-size: var(--font-md); }
.score-good { color: var(--color-success); }
.score-mid { color: var(--color-primary-dark); }
.score-low { color: var(--color-error); }
