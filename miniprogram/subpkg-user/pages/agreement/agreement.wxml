<view class="page">
  <view class="card">
    <text class="title">用户协议</text>
    <text class="update-date">更新日期：2025年7月</text>
    <text class="subtitle">生效日期：2025年7月1日</text>

    <block wx:for="{{sections}}" wx:key="title">
      <text class="section-title">{{item.title}}</text>
      <text class="content" wx:if="{{item.content}}">{{item.content}}</text>
      <block wx:if="{{item.items}}">
        <text class="content" wx:for="{{item.items}}" wx:for-item="li" wx:key="*this">{{li}}</text>
      </block>
    </block>
  </view>
</view>
