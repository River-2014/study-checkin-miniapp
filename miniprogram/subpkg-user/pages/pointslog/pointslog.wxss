/* ===== 积分明细样式 ===== */
.pl-page { padding-bottom: 30rpx; }

/* ===== 筛选 ===== */
.pl-filter {
  display: flex; padding: 20rpx; gap: 16rpx;
}
.pl-filter-tag {
  padding: 10rpx 32rpx; border-radius: 20rpx; font-size: 26rpx;
  background: var(--border-color); color: var(--text-secondary);
}
.pl-active { background: var(--color-primary); color: var(--text-on-primary); font-weight: 600; }

/* ===== 流水项 ===== */
.pl-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx; background: var(--bg-card); margin: 0 20rpx 12rpx;
  border-radius: 16rpx; box-shadow: 0 2rpx 12rpx var(--bg-overlay);
}
.pl-left { display: flex; flex-direction: column; gap: 6rpx; flex: 1; }
.pl-desc { font-size: 28rpx; color: var(--text-primary); }
.pl-time { font-size: 22rpx; color: var(--text-hint); }
.pl-amount { font-size: 34rpx; font-weight: 700; }
.pl-earn { color: var(--color-success); }
.pl-spend { color: var(--color-error); }
