.container { padding: 16rpx; padding-bottom: 40rpx; }
.time-bar { padding: 16rpx 0; text-align: right; }

.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }
.empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 26rpx; }
.loading { text-align: center; padding: 120rpx 0; color: #999; }

.mistake-item { padding: 12rpx 0; border-bottom: 1px solid #f0f0f0; }
.mistake-stem { font-size: 28rpx; color: #333; }
.mistake-meta { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.heatmap { display: flex; flex-wrap: wrap; gap: 12rpx; }
.heat-cell { padding: 12rpx 20rpx; border-radius: 8rpx; font-size: 24rpx; display: flex; flex-direction: column; gap: 4rpx; }
.heat-cell.hot { background: #ffebee; color: #c62828; }
.heat-cell.warm { background: #fff8e1; color: #e65100; }
.heat-cell.cool { background: #e8f5e9; color: #2e7d32; }
