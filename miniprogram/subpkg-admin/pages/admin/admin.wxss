.admin-page {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: var(--bg-page);
  min-height: 100vh;
}

/* ===== 新功能入口导航 ===== */
.nav-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.nav-btn {
  flex: 1;
  font-size: var(--font-sm);
  background: var(--color-primary);
  color: var(--text-on-primary);
  border-radius: 12rpx;
  padding: 12rpx 0;
}

/* ===== 题库统计 ===== */
.stats-card { text-align: center; }
.stats-row { padding: 16rpx 0; }
.stats-num { font-size: 64rpx; font-weight: bold; color: var(--color-primary); display: block; }
.stats-label { font-size: var(--font-sm); color: var(--text-hint); }

/* ===== 录题表单 ===== */
.add-form { margin-top: 16rpx; }
.form-row { margin-bottom: 20rpx; }
.form-label { font-size: var(--font-sm); color: var(--text-secondary); display: block; margin-bottom: 8rpx; font-weight: 500; }
.form-pickers { display: flex; gap: 20rpx; }
.picker-link { font-size: var(--font-md); color: var(--color-primary); font-weight: 500; }
.form-input {
  width: 100%; height: 160rpx;
  border: 2rpx solid #E8E8E8; border-radius: 12rpx;
  padding: 16rpx; font-size: var(--font-md);
  box-sizing: border-box;
}
.form-input-short {
  width: 100%; height: 72rpx;
  border: 2rpx solid #E8E8E8; border-radius: 12rpx;
  padding: 0 16rpx; font-size: var(--font-md);
  box-sizing: border-box;
}
.form-input-half {
  flex: 1; height: 72rpx;
  border: 2rpx solid #E8E8E8; border-radius: 12rpx;
  padding: 0 12rpx; font-size: var(--font-md);
  box-sizing: border-box;
}
.form-row-inline { display: flex; gap: 12rpx; }
.form-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.form-actions .btn { flex: 1; margin: 0; }

/* 爬取表单 */
.crawl-url-row, .crawl-mode-row, .crawl-selector-row {
  margin-top: 16rpx;
}
.radio-group {
  display: flex; gap: 32rpx; margin-top: 8rpx;
}
.radio-label {
  display: flex; align-items: center; gap: 8rpx;
  font-size: var(--font-md); color: var(--text-primary);
}

/* 爬取结果 */
.crawl-result {
  margin-top: 20rpx; padding: 20rpx;
  background: var(--bg-gray-light); border-radius: 12rpx;
}
.result-title { font-size: var(--font-md); font-weight: bold; margin-bottom: 12rpx; }
.text-success { color: var(--color-success); }
.text-error { color: var(--color-error); }
.result-rows { display: flex; flex-direction: column; gap: 6rpx; font-size: var(--font-sm); color: var(--text-secondary); }

/* 代码块 */
.code-block {
  background: #2D3436; color: var(--border-light);
  padding: 20rpx; border-radius: 12rpx;
  font-family: monospace; font-size: 24rpx;
  line-height: 1.8; margin-top: 12rpx;
  display: flex; flex-direction: column;
}

.desc-text {
  font-size: var(--font-sm); color: var(--text-secondary);
  line-height: 1.8;
  display: flex; flex-direction: column; gap: 6rpx;
}

.safety-card { background: var(--color-primary-light); }
.safety-card .desc-text { color: var(--color-error); }

/* ===== 试卷统计网格 ===== */
.paper-stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}
.paper-stat-item { text-align: center; }
.ps-num {
  font-size: var(--font-xxl); font-weight: bold;
  color: var(--text-secondary); display: block;
}
.ps-num.active { color: var(--color-success); }
.ps-num.meta { color: var(--text-hint); }
.ps-label { font-size: 24rpx; color: var(--text-hint); }
.paper-stats-actions {
  display: flex; gap: 12rpx;
  justify-content: center;
  margin-top: 8rpx;
}

/* ===== 试卷筛选 ===== */
.paper-filter {
  display: flex; align-items: center;
  gap: 12rpx; margin: 16rpx 0;
  flex-wrap: wrap;
}
.filter-search {
  flex: 1; min-width: 160rpx; height: 60rpx;
  border: 2rpx solid #E8E8E8; border-radius: 10rpx;
  padding: 0 12rpx; font-size: var(--font-sm);
  box-sizing: border-box;
}

/* ===== 试卷卡片 ===== */
.empty-hint {
  text-align: center; padding: 40rpx 0;
  color: var(--text-hint); font-size: var(--font-md);
}
.paper-card {
  background: var(--bg-gray-light);
  border-left: 6rpx solid var(--color-primary);
}
.paper-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}
.paper-title {
  font-size: var(--font-md); font-weight: 600; color: var(--text-primary);
  flex: 1; line-height: 1.4;
}
.paper-status {
  font-size: var(--font-xs); padding: 4rpx 12rpx; border-radius: 8rpx;
  margin-left: 12rpx; flex-shrink: 0;
}
.status-active { background: #E8F8E8; color: var(--color-success); }
.status-metadata_only { background: #F0F0F0; color: var(--text-hint); }
.status-draft { background: var(--color-primary-light); color: var(--color-primary); }

.paper-card-meta {
  display: flex; flex-wrap: wrap; gap: 8rpx 16rpx;
  font-size: 24rpx; color: var(--text-secondary);
  margin-bottom: 8rpx;
}
.paper-card-source {
  display: flex; gap: 16rpx;
  font-size: var(--font-xs); color: var(--text-hint);
  margin-bottom: 12rpx;
}
.paper-card-actions {
  display: flex; gap: 12rpx;
  justify-content: flex-end;
}

/* ===== 分页 ===== */
.pagination {
  display: flex; align-items: center;
  justify-content: center; gap: 16rpx;
  margin-top: 20rpx;
}
.page-info {
  font-size: var(--font-sm); color: var(--text-secondary);
}

/* ===== 通用按钮 ===== */
.btn-small {
  font-size: 24rpx; padding: 10rpx 24rpx;
  border-radius: 8rpx;
}
.btn-danger {
  background: var(--color-error-light); color: var(--color-error);
}
