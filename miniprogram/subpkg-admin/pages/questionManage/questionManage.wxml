<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{subjects}}" bindchange="onSubjectChange" value="{{}}">
      <view class="filter-item">{{subject || '学科'}}</view>
    </picker>
    <picker mode="selector" range="{{grades}}" bindchange="onGradeChange">
      <view class="filter-item">{{grade || '年级'}}</view>
    </picker>
    <picker mode="selector" range="{{types}}" bindchange="onTypeChange">
      <view class="filter-item">{{type || '题型'}}</view>
    </picker>
    <picker mode="selector" range="{{statuses}}" range-key="label" bindchange="onStatusChange">
      <view class="filter-item">{{status || '状态'}}</view>
    </picker>
    <input class="filter-input" placeholder="搜索题干..." value="{{keyword}}" bindinput="onKeywordInput" />
  </view>
  <view class="filter-actions">
    <button size="mini" bindtap="search" data-reset="{{true}}">搜索</button>
    <button size="mini" type="default" bindtap="resetFilters">重置</button>
    <button size="mini" type="warn" bindtap="startAiTag" loading="{{aiTagging}}">AI标注</button>
  </view>

  <!-- 题目列表 -->
  <scroll-view class="question-list" scroll-y bindscrolltolower="loadMore">
    <block wx:for="{{questions}}" wx:key="_id">
      <view class="question-item {{selectedIds.indexOf(item._id) >= 0 ? 'selected' : ''}}"
            bindtap="toggleSelect" data-id="{{item._id}}">
        <view class="q-stem">{{item.stem}}</view>
        <view class="q-meta">
          <text class="tag">{{item.subject}}</text>
          <text class="tag">{{item.grade}}</text>
          <text class="tag">{{item.type}}</text>
          <text class="tag">{{item.difficulty}}</text>
          <text class="tag tag-status">{{item.status || 'active'}}</text>
          <text class="tag" bindtap="preview" data-id="{{item._id}}">预览</text>
        </view>
      </view>
    </block>
    <view wx:if="{{questions.length === 0}}" class="empty">暂无题目</view>
    <view wx:if="{{hasMore}}" class="load-more">加载更多...</view>
  </scroll-view>

  <!-- 批量操作栏 -->
  <view class="batch-bar" wx:if="{{selectedIds.length > 0}}">
    <text>已选 {{selectedIds.length}} 项</text>
    <button size="mini" type="primary" bindtap="batchUpdate" data-status="approved">批量通过</button>
    <button size="mini" type="warn" bindtap="batchUpdate" data-status="rejected">批量拒绝</button>
    <button size="mini" bindtap="batchUpdate" data-status="archived">批量归档</button>
  </view>

  <!-- 预览弹窗 -->
  <view class="preview-mask" wx:if="{{previewVisible}}" bindtap="closePreview">
    <view class="preview-content" catchtap="">
      <text class="preview-stem">{{previewQuestion.stem}}</text>
      <view class="preview-meta">
        <text>{{previewQuestion.subject}} | {{previewQuestion.grade}} | {{previewQuestion.type}} | {{previewQuestion.difficulty}}</text>
      </view>
      <button bindtap="closePreview">关闭</button>
    </view>
  </view>
</view>
