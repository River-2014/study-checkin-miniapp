{
  "name": "xiaoshengchu-crawler",
  "version": "1.0.0",
  "description": "小升初打卡小程序 —— 题库爬虫脚本",
  "main": "crawler.js",
  "scripts": {
    "start": "node crawler.js",
    "appsj": "node run_appsj.js",
    "appsj:math": "node run_appsj.js 数学",
    "appsj:chinese": "node run_appsj.js 语文",
    "appsj:english": "node run_appsj.js 英语",
    "shijuan1": "node run_shijuan1.js",
    "shijuan1:math": "node run_shijuan1.js 数学 六年级 10",
    "math": "node crawler.js --source=all --subject=数学",
    "chinese": "node crawler.js --source=all --subject=语文",
    "english": "node crawler.js --source=all --subject=英语",
    "all": "node crawler.js --source=all --subject=all --grade=all"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "iconv-lite": "^0.6.3",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "node-unrar-js": "^2.0.2"
  }
}
